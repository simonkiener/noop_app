            "value": "夜間計算"
          }
        }
      }
    },
    "Overnight only": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Nur über Nacht"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Solo durante la noche"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Solo di notte"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "仅夜间"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "僅限夜間"
          }
        }
      }
    },
    "Overnight sleep staging, resting heart rate, skin-temperature trend, motion and battery, read straight off the ring.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Nächtliche Schlafphasen, Ruheherzfrequenz, Hauttemperatur-Trend, Bewegung und Akku, direkt vom Ring gelesen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Fases del sueño nocturno, frecuencia cardíaca en reposo, tendencia de temperatura de la piel, movimiento y batería, leídos directamente del anillo."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Fasi del sonno notturno, frequenza cardiaca a riposo, andamento della temperatura cutanea, movimento e batteria, letti direttamente dall'anello."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "夜间睡眠分期、静息心率、皮肤温度趋势、运动和电量，直接从戒指读取。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "夜間睡眠分期、靜息心率、皮膚溫度趨勢、運動與電量，直接從戒指讀取。"
          }
        }
      }
    },
    "Override the automatic fit with your own steps-per-motion value. Useful if your phone has no step history to learn from, or the estimate runs consistently high or low. Set it back to auto by dragging to the far left.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Überschreibe die automatische Anpassung mit deinem eigenen Schritte-pro-Bewegung-Wert. Nützlich, wenn dein Telefon keinen Schrittverlauf zum Lernen hat oder die Schätzung durchgehend zu hoch oder zu niedrig liegt. Zurück auf Automatik: ganz nach links ziehen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Sustituye el ajuste automático con tu propio valor de pasos por movimiento. Útil si tu teléfono no tiene historial de pasos del que aprender, o si la estimación resulta siempre alta o baja. Vuelve al modo automático arrastrando hasta el extremo izquierdo."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Sostituisci l'adattamento automatico con il tuo valore di passi-per-movimento. Utile se il tuo telefono non ha una cronologia dei passi da cui imparare, o se la stima risulta costantemente alta o bassa. Riportalo su auto trascinando all'estrema sinistra."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "用你自己的每运动步数值覆盖自动拟合。当你的手机没有可供学习的步数历史，或估算持续偏高或偏低时会很有用。将滑块拖到最左端即可恢复为自动。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "用你自己的每運動步數值覆寫自動擬合。當你的手機沒有可供學習的步數歷史，或估算持續偏高或偏低時會很有用。將滑桿拖到最左端即可恢復為自動。"
          }
        }
      }
    },

        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tono simpático frente a parasimpático a partir de la VFC en el dominio de la frecuencia. Un valor más alto tiende al simpático (hacia el estrés)."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Tono simpatico contro parasimpatico dall'HRV nel dominio delle frequenze. Valori più alti pendono verso il simpatico (lato stress)."

    "Replace this device's data with one of the backups in your folder. This overwrites current data, so back up first if you're unsure.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ersetze die Daten dieses Geräts durch eine der Sicherungen in deinem Ordner. Das überschreibt aktuelle Daten – sichere also zuerst, wenn du unsicher bist."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Reemplaza los datos de este dispositivo con uno de los respaldos de tu carpeta. Esto sobrescribe los datos actuales, así que haz un respaldo primero si no estás seguro."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Sostituisci i dati di questo dispositivo con uno dei backup nella tua cartella. Questo sovrascrive i dati attuali, quindi fai prima un backup se hai dubbi."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "用你文件夹中的某个备份替换这台设备的数据。这会覆盖当前数据，如果你不确定，请先备份。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "用你資料夾中的某個備份替換這台裝置的資料。這會覆蓋目前資料，如果你不確定，請先備份。"
          }
        }
      }
    },

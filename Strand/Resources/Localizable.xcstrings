          }
        }
      }
    },
    "Read your heart rate, HRV, blood oxygen, respiratory rate, sleep, steps and energy straight from Apple Health, and write NOOP's strap-derived metrics back. Everything stays on %@.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Lies deine Herzfrequenz, HRV, deinen Blutsauerstoff, deine Atemfrequenz, deinen Schlaf, deine Schritte und Energie direkt aus Apple Health und schreibe NOOPs strap-basierte Metriken zurück. Alles bleibt auf %@."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Lee tu frecuencia cardíaca, VFC, oxígeno en sangre, frecuencia respiratoria, sueño, pasos y energía directamente desde Apple Health, y escribe de vuelta las métricas de NOOP derivadas de la pulsera. Todo permanece en %@."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Leggi la tua frequenza cardiaca, l'HRV, l'ossigeno nel sangue, la frequenza respiratoria, il sonno, i passi e l'energia direttamente da Apple Health, e riscrivi i parametri di NOOP derivati dalla fascia. Tutto resta su %@."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "直接从 Apple 健康读取你的心率、HRV、血氧、呼吸频率、睡眠、步数和能量，并将 NOOP 从手环推导出的指标写回。一切都留在 %@ 上。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "直接從 Apple 健康讀取你的心率、HRV、血氧、呼吸頻率、睡眠、步數和能量，並將 NOOP 從手環推導出的指標寫回。一切都留在 %@ 上。"
          }
        }
      }
    },

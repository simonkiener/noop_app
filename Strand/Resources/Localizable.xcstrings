          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous avez dit : %@"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Hai detto: %@"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",

    "Make %@ your active device now? It will provide your live data. You can change this any time.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ jetzt zu deinem aktiven Gerät machen? Es liefert dann deine Live-Daten. Du kannst das jederzeit ändern."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Hacer de %@ tu dispositivo activo ahora? Proporcionará tus datos en vivo. Puedes cambiarlo en cualquier momento."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Rendere %@ il tuo dispositivo attivo ora? Fornirà i tuoi dati in diretta. Puoi cambiarlo in qualsiasi momento."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "现在将 %@ 设为你的活跃设备？它将提供你的实时数据。你可以随时更改。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "現在將 %@ 設為你的活躍裝置？它將提供你的即時資料。你可以隨時更改。"
          }
        }
      }
    },
    "Make %@ your active strap? From now on it provides your live data. %@'s history stays exactly as it is. Only new days come from %@.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ zu deinem aktiven Strap machen? Ab jetzt liefert er deine Live-Daten. Der Verlauf von %2$@ bleibt genau, wie er ist. Nur neue Tage kommen von %3$@."
          }
        },
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "Make %1$@ your active strap? From now on it provides your live data. %2$@'s history stays exactly as it is, only new days come from %3$@."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Hacer de %@ tu pulsera activa? A partir de ahora proporciona tus datos en vivo. El historial de %@ se queda exactamente como está. Solo los días nuevos vienen de %@."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Rendere %1$@ la tua fascia attiva? D'ora in poi fornirà i tuoi dati in diretta. La cronologia di %2$@ resta esattamente com'è, solo i nuovi giorni provengono da %3$@."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "将 %1$@ 设为你的活跃手环？从现在起，它将提供你的实时数据。%2$@ 的历史保持原样，只有新的日期来自 %3$@。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "將 %1$@ 設為你的活躍手環？從現在起，它將提供你的即時資料。%2$@ 的歷史保持原樣，只有新的日期來自 %3$@。"
          }
        }
      }
    },
    "Make active": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Aktiv setzen"
          }
        },

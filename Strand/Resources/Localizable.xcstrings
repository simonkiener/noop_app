    "Wake your Amazfit / Zepp band and make sure it isn't connected to the Zepp app right now.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wecke dein Amazfit-/Zepp-Band und stelle sicher, dass es gerade nicht mit der Zepp-App verbunden ist."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Despierta tu banda Amazfit / Zepp y asegúrate de que no esté conectada a la app Zepp en este momento."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Risveglia il tuo braccialetto Amazfit / Zepp e assicurati che in questo momento non sia connesso all'app Zepp."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "唤醒你的 Amazfit / Zepp 手环，并确保它此刻没有连接到 Zepp 应用。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "喚醒你的 Amazfit / Zepp 手環，並確認它目前沒有連線到 Zepp 應用程式。"
          }
        }
      }
    },
    "Wake your Mi Band and make sure it isn't connected to the Mi Fitness / Zepp Life app right now.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wecke dein Mi Band und stelle sicher, dass es gerade nicht mit der Mi-Fitness-/Zepp-Life-App verbunden ist."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",

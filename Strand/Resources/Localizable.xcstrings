    "Other metrics (R-R, frames, battery, history) need a full sync.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Andere Metriken (R-R, Frames, Akku, Verlauf) brauchen eine volle Synchronisierung."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Otras métricas (R-R, tramas, batería, historial) necesitan una sincronización completa."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Altri parametri (R-R, frame, batteria, cronologia) richiedono una sincronizzazione completa."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "其他指标（R-R、帧、电量、历史）需要一次完整同步。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "其他指標（R-R、幀、電量、歷史）需要一次完整同步。"
          }
        }
      }
    },
    "Other sources don’t offload raw per-second data on-device.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Andere Quellen übertragen keine rohen Sekundendaten auf das Gerät."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Otras fuentes no descargan datos en bruto por segundo en el dispositivo."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Altre sorgenti non scaricano dati grezzi al secondo sul dispositivo."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "其他来源不会在设备上卸载原始的逐秒数据。"

    "Not recording. Strap not connected. Tap to connect.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Keine Aufzeichnung. Strap nicht verbunden. Tippe zum Verbinden."
          }

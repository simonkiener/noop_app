          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "安裝於 App Store 之外"
          }
        }
      }
    },
    "Installing NOOP's key and confirming the ring answers only to NOOP. Keep the ring close and do not open the Oura app.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOPs Schlüssel wird installiert und bestätigt, dass der Ring nur noch NOOP antwortet. Halte den Ring in der Nähe und öffne die Oura-App nicht."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Instalando la clave de NOOP y confirmando que el anillo responde solo a NOOP. Mantén el anillo cerca y no abras la app de Oura."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Installazione della chiave di NOOP e conferma che l'anello risponda solo a NOOP. Tieni l'anello vicino e non aprire l'app Oura."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "正在安装 NOOP 的密钥，并确认戒指只响应 NOOP。请让戒指保持在附近，且不要打开 Oura 应用。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "正在安裝 NOOP 的金鑰，並確認戒指只回應 NOOP。請讓戒指保持在附近，且不要打開 Oura 應用程式。"
          }
        }
      }
    },

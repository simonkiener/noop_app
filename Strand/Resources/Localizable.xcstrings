    "Steps, active energy and logged workouts feed Effort. Dense and reliable.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Schritte, aktive Energie und erfasste Workouts fließen in die Belastung ein. Dicht und verlässlich."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los pasos, la energía activa y los entrenamientos registrados alimentan Esfuerzo. Denso y fiable."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Passi, energia attiva e allenamenti registrati alimentano lo Sforzo. Dati densi e affidabili."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "步数、活动能量和已记录的锻炼会计入消耗。数据密集且可靠。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "步數、活動能量和已記錄的鍛鍊會提供給消耗。密集且可靠。"
          }
        }
      }
    },

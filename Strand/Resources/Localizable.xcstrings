    },
    "Couldn't safely back up right now. Recent changes are still in the write-ahead log.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Konnte gerade nicht sicher sichern. Jüngste Änderungen liegen noch im Write-Ahead-Log."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudo hacer la copia de seguridad de forma segura ahora mismo. Los cambios recientes siguen en el registro de escritura anticipada."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossibile fare il backup in sicurezza adesso. Le modifiche recenti sono ancora nel write-ahead log."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "目前无法安全备份。最近的更改仍在预写日志中。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "目前無法安全備份。最近的變更仍在預寫日誌中。"
          }
        }
      }
    },
    "Couldn't safely export right now. Recent changes are still in the database's write-ahead log. Close any in-flight sync, then try again.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Konnte gerade nicht sicher exportieren. Jüngste Änderungen liegen noch im Write-Ahead-Log der Datenbank. Beende laufende Synchronisierungen und versuch es erneut."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudo exportar de forma segura ahora mismo. Los cambios recientes siguen en el registro de escritura anticipada de la base de datos. Cierra cualquier sincronización en curso y vuelve a intentarlo."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossibile esportare in sicurezza adesso. Le modifiche recenti sono ancora nel write-ahead log del database. Chiudi eventuali sincronizzazioni in corso, poi riprova."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "目前无法安全导出。最近的更改仍在数据库的预写日志中。请先结束正在进行的同步，然后重试。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "目前無法安全匯出。最近的變更仍在資料庫的預寫日誌中。請先結束任何進行中的同步，然後再試一次。"
          }
        }
      }
    },
    "Couldn't start. Needs a connected strap and a resting heart rate.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Konnte nicht starten. Braucht einen verbundenen Strap und eine Ruheherzfrequenz."
          }
        },
        "es": {

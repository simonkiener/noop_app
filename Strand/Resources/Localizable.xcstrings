        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "强度提醒和智能闹钟触发时会立即轻叩你的手腕。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",

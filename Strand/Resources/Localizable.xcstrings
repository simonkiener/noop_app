    "Days with higher %@ tend to be your better-mood days.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Tage mit höherem %@ sind tendenziell deine Tage mit besserer Stimmung."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los días con %@ más alto suelen ser tus días de mejor ánimo."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I giorni con %@ più alto tendono a essere quelli in cui il tuo umore è migliore."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ 较高的日子，往往是你心情较好的日子。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ 較高的日子，往往是你心情較好的日子。"
          }
        }
      }
    },
    "Days with higher %@ tend to be your lower-mood days.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Tage mit höherem %@ sind tendenziell deine Tage mit schlechterer Stimmung."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los días con %@ más alto suelen ser tus días de peor ánimo."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I giorni con %@ più alto tendono a essere quelli in cui il tuo umore è peggiore."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ 较高的日子，往往是你心情较差的日子。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ 較高的日子，往往是你心情較差的日子。"
          }
        }
      }
    },

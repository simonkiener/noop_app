    "Heart rate plus active energy give a solid daily cardiovascular load. An on-watch workout sharpens it further.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Herzfrequenz plus aktive Energie ergeben eine solide tägliche kardiovaskuläre Last. Ein Workout auf der Uhr schärft sie weiter."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La frecuencia cardíaca más la energía activa dan una carga cardiovascular diaria sólida. Un entrenamiento registrado en el reloj la afina aún más."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Frequenza cardiaca ed energia attiva danno un solido carico cardiovascolare giornaliero. Un allenamento avviato dall'orologio lo rende ancora più preciso."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "心率加上活动能量就能得出可靠的每日心血管负荷。在手表上记录锻炼可以让它更精确。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "心率加上活動能量能給出可靠的每日心血管負荷。在手錶上記錄鍛鍊能讓它更精準。"
          }
        }
      }
    },

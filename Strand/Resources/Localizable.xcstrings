    "Collect a few logged intervention days before reading the effect. Baseline and imported metrics stay in place.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sammle ein paar erfasste Interventionstage, bevor du den Effekt liest. Basislinie und importierte Metriken bleiben bestehen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Registra algunos días de intervención antes de leer el efecto. La línea base y las métricas importadas se mantienen."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Raccogli qualche giorno di intervento registrato prima di leggere l'effetto. La linea di base e le metriche importate restano al loro posto."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "先记录几天干预数据，再来解读效果。基线和导入的指标会保持不变。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",

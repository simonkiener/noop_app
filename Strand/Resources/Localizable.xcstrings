    "Remove %@? NOOP will stop connecting to it. Its recorded data is kept and you can re-add it any time.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ entfernen? NOOP verbindet sich dann nicht mehr damit. Die aufgezeichneten Daten bleiben, und du kannst es jederzeit wieder hinzufügen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Eliminar %@? NOOP dejará de conectarse a este dispositivo. Sus datos grabados se conservan y puedes volver a añadirlo cuando quieras."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Rimuovere %@? NOOP smetterà di connettersi ad esso. I dati registrati vengono conservati e puoi riaggiungerlo in qualsiasi momento."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "移除 %@？NOOP 将停止连接它。它已记录的数据会保留，你可以随时重新添加它。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "移除 %@？NOOP 將停止連接它。它已記錄的資料會保留，你可以隨時重新新增它。"
          }
        }
      }
    },

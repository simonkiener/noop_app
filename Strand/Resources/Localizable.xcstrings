    "Offers to save a workout when it spots sustained elevated heart rate": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Bietet an, ein Workout zu speichern, wenn anhaltend erhöhte Herzfrequenz erkannt wird"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ofrece guardar un entrenamiento cuando detecta frecuencia cardíaca elevada sostenida"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Propone di salvare un allenamento quando rileva una frequenza cardiaca elevata e prolungata"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "当它发现持续升高的心率时，会建议保存一次锻炼"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "當它發現持續升高的心率時，會建議保存一次鍛鍊"
          }
        }
      }
    },

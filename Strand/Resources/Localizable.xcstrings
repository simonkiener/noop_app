          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tout reste sur ce Mac. Importez votre historique une fois, il est à vous."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Tutto resta su questo Mac. Importa la tua cronologia una volta, poi è tua."
          }
        },
        "ru": {

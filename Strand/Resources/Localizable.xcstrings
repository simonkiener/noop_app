    "Choose Light, Dark, or follow your system. Dark is the signature near-black; Light keeps the same clean look on a bright canvas.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wähle Hell, Dunkel oder folge deinem System. Dunkel ist das charakteristische Fast-Schwarz; Hell behält denselben klaren Look auf heller Fläche."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elige Claro, Oscuro o seguir tu sistema. Oscuro es el casi negro característico; Claro mantiene el mismo aspecto limpio sobre un lienzo brillante."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Scegli Chiaro, Scuro o segui il sistema. Lo scuro è il caratteristico quasi-nero; il chiaro mantiene lo stesso aspetto pulito su uno sfondo luminoso."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择浅色、深色，或跟随系统。深色是标志性的近黑色；浅色在明亮画布上保持同样简洁的外观。"
          }
        },

        }
      }
    },
    "Your last %lld hours have stayed in the high band. A few minutes of paced breathing can help downshift your nervous system.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Deine letzten %lld Stunden lagen durchgehend im hohen Band. Ein paar Minuten getaktetes Atmen können helfen, dein Nervensystem runterzuschalten."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tus últimas %lld horas se han mantenido en la banda alta. Unos minutos de respiración pautada pueden ayudar a bajar el ritmo de tu sistema nervioso."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Le tue ultime %lld ore sono rimaste nella fascia alta. Qualche minuto di respirazione ritmata può aiutare a calmare il tuo sistema nervoso."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你过去 %lld 小时一直处于高位区间。几分钟的节律呼吸有助于让你的神经系统降档。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "你過去 %lld 小時一直處於高位區間。幾分鐘的節律呼吸有助於讓你的神經系統降檔。"
          }
        }
      }
    },
    "Your last %lld readings: %@ %@, holding steady.": {

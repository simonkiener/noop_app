    },
    "Connect your strap for the felt cue. The sweep paces you with one buzz on the inhale, two on the exhale.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verbinde deinen Strap für das spürbare Signal. Der Durchlauf taktet dich mit einem Vibrieren beim Einatmen, zwei beim Ausatmen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Conecta tu pulsera para la señal táctil. El barrido te marca el ritmo con una vibración al inhalar y dos al exhalar."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Collega la tua fascia per il segnale percepito, la sequenza ti scandisce il ritmo con una vibrazione durante l'inspirazione, due durante l'espirazione."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "连接你的手环以获得可感知的提示，扫掠会以吸气一次震动、呼气两次的方式为你把握节奏。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "連接你的手環以獲得可感知的提示，掃掠會以吸氣一次震動、呼氣兩次的方式為你把握節奏。"
          }
        }
      }
    },

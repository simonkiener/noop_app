          }
        }
      }
    },
    "No workout, stress, recovery, sleep, HRV, resting-HR, strain, respiratory-rate or skin-temp readings fell inside %@. Wear your strap a few more days, or pick a wider range, then export again.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Keine Workout-, Stress-, Erholungs-, Schlaf-, HRV-, Schlaf-HF-, Belastungs-, Atemfrequenz- oder Hauttemperatur-Messwerte lagen in %@. Trage deinen Strap ein paar Tage mehr oder wähle einen größeren Zeitraum, dann exportiere erneut."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No hubo lecturas de entrenamiento, estrés, recuperación, sueño, VFC, frecuencia cardíaca en reposo, esfuerzo, frecuencia respiratoria ni temperatura cutánea dentro de %@. Lleva tu pulsera unos días más, o elige un rango más amplio, y exporta de nuevo."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Nessuna lettura di allenamento, stress, recupero, sonno, HRV, FC a riposo, carico, frequenza respiratoria o temperatura cutanea è rientrata in %@. Indossa la tua fascia per qualche altro giorno, o scegli un intervallo più ampio, poi esporta di nuovo."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在 %@ 内没有任何锻炼、压力、恢复、睡眠、HRV、静息心率、强度、呼吸频率或皮肤温度读数。请再佩戴手环几天，或选择更宽的范围，然后重新导出。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在 %@ 內沒有任何鍛鍊、壓力、恢復、睡眠、HRV、靜息心率、強度、呼吸頻率或皮膚溫度讀數。請再佩戴手環幾天，或選擇更寬的範圍，然後重新匯出。"
          }
        }
      }
    },
    "No workouts found. Point at a Hevy CSV export or a Liftosaur JSON export.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Keine Workouts gefunden. Wähle einen Hevy-CSV-Export oder einen Liftosaur-JSON-Export."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se encontraron entrenamientos. Selecciona una exportación CSV de Hevy o una exportación JSON de Liftosaur."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Nessun allenamento trovato. Indica un'esportazione CSV di Hevy o un'esportazione JSON di Liftosaur."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "未找到训练记录。请选择 Hevy CSV 导出或 Liftosaur JSON 导出文件。"

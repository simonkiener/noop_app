    "Choose how NOOP looks. The whole app updates as you tap. You can change this any time in Settings → Appearance.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wähle, wie NOOP aussieht. Die ganze App aktualisiert sich beim Tippen. Du kannst das jederzeit unter Einstellungen → Erscheinungsbild ändern."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",

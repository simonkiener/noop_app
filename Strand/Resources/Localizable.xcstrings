        }
      }
    },
    "HR held steady (%lld → %lld). Try a paced breath instead.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "HF blieb stabil (%1$lld → %2$lld). Versuch stattdessen einen getakteten Atemzug."
          }
        },
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "HR held steady (%1$lld → %2$lld). Try a paced breath instead."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La FC se mantuvo estable (%lld → %lld). Prueba mejor una respiración guiada."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "FC rimasta stabile (%lld → %lld). Prova invece una respirazione guidata."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "心率保持平稳（%1$lld → %2$lld）。试试有节奏的呼吸。"

    "Over your readings, %@ and %@ move largely independently. No clear relationship.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Über deine Messwerte hinweg bewegen sich %1$@ und %2$@ weitgehend unabhängig. Kein klarer Zusammenhang."
          }
        },
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "Over your readings, %1$@ and %2$@ move largely independently. No clear relationship."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "En tus lecturas, %@ y %@ se mueven en gran medida de forma independiente. Sin relación clara."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Nelle tue letture, %@ e %@ si muovono in gran parte in modo indipendente. Nessuna relazione chiara."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在你的读数中，%@与%@基本各自变化。没有明显关联。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "從你的讀數來看，%@ 和 %@ 大致上各走各的。沒有明顯關係。"

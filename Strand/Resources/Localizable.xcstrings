    "Make it yours": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Mach es zu deinem"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Hazlo tuyo"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Rendilo tuo"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "打造属于你的"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "打造屬於你的"
          }
        }
      }
    },
    "Make sure it isn't already connected to another app (Zwift, the gym's app, a bike computer…).": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Stelle sicher, dass es nicht schon mit einer anderen App verbunden ist (Zwift, der App des Studios, einem Fahrradcomputer …)."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Asegúrate de que no esté ya conectada a otra app (Zwift, la app del gimnasio, un ciclocomputador…)."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Assicurati che non sia già connesso a un'altra app (Zwift, l'app della palestra, un ciclocomputer…)."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "确认它没有已连接到其他应用（Zwift、健身房的应用、码表等）。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "請確認它沒有已連接到其他 App（Zwift、健身房的 App、自行車碼錶…）。"
          }
        }
      }
    },
    "Make sure it isn't connected to another app (a bike computer, the brand's own app…).": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Stelle sicher, dass es nicht mit einer anderen App verbunden ist (einem Fahrradcomputer, der App der Marke …)."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Asegúrate de que no esté conectada a otra app (un ciclocomputador, la app de la propia marca…)."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Assicurati che non sia connesso a un'altra app (un ciclocomputer, l'app ufficiale del marchio…)."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "确认它没有连接到其他应用（码表、品牌自家应用等）。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "請確認它沒有連接到其他 App（自行車碼錶、品牌自家的 App…）。"
          }
        }
      }
    },
    "Make sure it's NOT connected to the official WHOOP app right now.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Stelle sicher, dass er gerade NICHT mit der offiziellen WHOOP-App verbunden ist."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Asegúrate de que NO esté conectada a la app oficial de WHOOP ahora mismo."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Assicurati che in questo momento NON sia connesso all'app ufficiale WHOOP."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "确认它此刻没有连接到官方 WHOOP 应用。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "請確認它此刻「沒有」連接到官方 WHOOP App。"
          }
        }
      }
    },
    "Make sure it's awake and not connected elsewhere.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Stelle sicher, dass er wach und nirgendwo anders verbunden ist."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Asegúrate de que esté despierta y no conectada en otro sitio."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Assicurati che sia attiva e non connessa altrove."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "确保它已唤醒且未在别处连接。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "確保它已喚醒且未在別處連接。"
          }
        }
      }
    },
    "Make sure the Oura app is fully closed. A ring answers one owner at a time.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Stelle sicher, dass die Oura-App vollständig geschlossen ist. Ein Ring antwortet immer nur einem Besitzer."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Asegúrate de que la app de Oura esté completamente cerrada. Un anillo responde a un dueño a la vez."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Assicurati che l'app Oura sia completamente chiusa. Un anello risponde a un solo proprietario alla volta."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "确认 Oura 应用已完全关闭。戒指一次只响应一个主人。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "請確認 Oura App 已完全關閉。戒指一次只回應一個持有者。"
          }
        }
      }
    },
    "Make the strap do things, tap to act, walk away to lock, train by feel.": {
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Lass den Strap Dinge tun, tippen zum Auslösen, weggehen zum Sperren, nach Gefühl trainieren."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Make the strap do things, tap to act, walk away to lock, train by feel."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Haz que la correa haga cosas: toca para actuar, aléjate para bloquear, entrena por sensaciones."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Faites faire des choses au bracelet, tapez pour agir, éloignez-vous pour verrouiller, entraînez-vous au ressenti."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Fai fare cose alla fascia, tocca per agire, allontanati per bloccare, allenati a sensazione."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Настройте действия браслета: коснитесь, чтобы выполнить команду; отойдите, чтобы заблокировать; тренируйтесь, ориентируясь по сигналам."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "让手环为你做事，，轻点执行，走开即锁定，凭感觉训练。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "讓手環為你做事，，輕點執行，走開即鎖定，憑感覺訓練。"
          }
        }
      }
    },
    "Make the strap do things: tap to act, walk away to lock, train by feel.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Bring den Strap dazu, Dinge zu tun: Tippen zum Handeln, Weggehen zum Sperren, Training nach Gefühl."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Haz que la pulsera haga cosas: toca para actuar, aléjate para bloquear, entrena por sensaciones."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Fai fare cose alla fascia, tocca per agire, allontanati per bloccare, allenati a sensazione."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "让手环为你做事，轻点执行，走开即锁定，凭感觉训练。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "讓手環為你做事，輕點執行，走開即鎖定，憑感覺訓練。"
          }
        }
      }
    },
    "Make this your active device?": {

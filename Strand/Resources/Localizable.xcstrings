    "Bond your strap on the Live screen to feel the transitions hands-free.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verbinde deinen Strap im Live-Bildschirm, um die Übergänge freihändig zu spüren."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Bond your strap on the Live screen to feel the transitions hands-free."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Vincula tu pulsera en la pantalla En vivo para sentir las transiciones sin usar las manos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Associez votre bracelet sur l'écran En direct pour ressentir les transitions sans les mains."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Abbina la tua fascia nella schermata In diretta per sentire le transizioni a mani libere."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Подключите браслет на экране «В реальном времени», чтобы ориентироваться по вибросигналам."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在「实时」界面绑定你的手环，无需动手即可感受各阶段切换。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在「即時」畫面綁定你的手環，無需動手即可感受各階段切換。"
          }
        }
      }
    },
    "Bonded · streaming": {
      "localizations": {
        "de": {

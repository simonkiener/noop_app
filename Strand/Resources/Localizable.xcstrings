            "value": "NOOP %@"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP %@"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP %@"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP %@"
          }
        }
      }
    },
    "NOOP %@ is here. Tap to read what's new.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP %@ ist da. Tippe, um zu lesen, was neu ist."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP %@ ya está aquí. Toca para leer las novedades."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP %@ è arrivato. Tocca per leggere le novità."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP %@ 来了。点按查看新内容。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP %@ 來了。點擊查看新功能。"
          }
        }
      }
    },
    "NOOP Charge": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP-Erholung"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Carga de NOOP"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Carica NOOP"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP 能量"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP 能量"
          }
        }
      }
    },
    "NOOP can read a coarse menstrual-cycle phase from your nightly skin temperature, entirely on your device. It is awareness only: not contraception, not a fertility predictor, not a medical service.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP kann eine grobe Menstruationszyklus-Phase aus deiner nächtlichen Hauttemperatur ablesen, komplett auf deinem Gerät. Es dient nur dem Bewusstsein: keine Verhütung, kein Fruchtbarkeits-Vorhersager, kein medizinischer Dienst."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP puede leer una fase aproximada del ciclo menstrual a partir de tu temperatura de la piel nocturna, completamente en tu dispositivo. Es solo información: no es anticoncepción, ni un predictor de fertilidad, ni un servicio médico."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP può leggere una fase approssimativa del ciclo mestruale dalla tua temperatura cutanea notturna, interamente sul tuo dispositivo. È solo a scopo informativo: non è un metodo contraccettivo, non è un predittore di fertilità, non è un servizio medico."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP 可以从你的夜间皮肤温度中读取粗略的月经周期阶段，完全在你的设备上。它仅供了解参考：不是避孕手段，不是生育力预测工具，也不是医疗服务。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP 可以從你的夜間皮膚溫度中讀取粗略的月經週期階段，完全在你的裝置上。它僅供了解參考：不是避孕手段，不是生育力預測工具，也不是醫療服務。"
          }
        }
      }
    },
    "NOOP can run off only an Apple Watch, no chest strap needed. The watch is the sensor; NOOP does the thinking on your phone, computing Charge, Rest, Effort and your Fitness Age from your Health data, all on-device.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP kann allein mit einer Apple Watch laufen, kein Brustgurt nötig. Die Uhr ist der Sensor; NOOP übernimmt das Denken auf deinem Telefon und berechnet Erholung, Schlaf, Belastung und dein Fitnessalter aus deinen Health-Daten, alles auf dem Gerät."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP puede funcionar solo con un Apple Watch, sin necesidad de banda de pecho. El reloj es el sensor; NOOP hace el trabajo en tu teléfono, calculando Carga, Descanso, Esfuerzo y tu Edad fitness a partir de tus datos de Salud, todo en el dispositivo."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP può funzionare solo con un Apple Watch, senza bisogno di una fascia toracica. L'orologio è il sensore; NOOP fa i calcoli sul tuo telefono, calcolando carica, riposo, sforzo e la tua Età di forma fisica dai tuoi dati Health, tutto sul dispositivo."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP 可以仅靠一块 Apple Watch 运行，无需胸带。手表是传感器；NOOP 在你的手机上做运算，从你的健康数据中计算出能量、休息、消耗和你的体能年龄，全部在设备本地。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP 可以僅靠一塊 Apple Watch 運行，無需胸帶。手錶是感測器；NOOP 在你的手機上做運算，從你的健康資料中計算出能量、休息、消耗和你的體能年齡，全部在裝置本地。"
          }
        }
      }
    },
    "NOOP can tap your wrist when your %@ needs you. No glance at the screen required.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP kann dein Handgelenk antippen, wenn dein %@ dich braucht. Kein Blick auf den Bildschirm nötig."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP puede tocar tu muñeca cuando tu %@ te necesita. Sin necesidad de mirar la pantalla."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP può darti un colpetto al polso quando il tuo %@ ha bisogno di te. Senza dover guardare lo schermo."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "当你的 %@ 需要你时，NOOP 可以轻拍你的手腕。无需看屏幕。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "當你的 %@ 需要你時，NOOP 可以輕拍你的手腕。無需看螢幕。"
          }
        }
      }
    },
    "NOOP computed": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Von NOOP berechnet"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Calculado por NOOP"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Calcolato da NOOP"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "由 NOOP 计算"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "由 NOOP 計算"
          }
        }
      }
    },
    "NOOP estimates your steps from your WHOOP's motion, calibrated to your phone's step count. It's an estimate, not a step counter. A WHOOP 4.0 doesn't transmit steps.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP schätzt deine Schritte aus der Bewegung deines WHOOP, kalibriert an der Schrittzahl deines Telefons. Es ist eine Schätzung, kein Schrittzähler. Ein WHOOP 4.0 überträgt keine Schritte."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP estima tus pasos a partir del movimiento de tu WHOOP, calibrado con el recuento de pasos de tu teléfono. Es una estimación, no un podómetro. Una WHOOP 4.0 no transmite pasos."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP stima i tuoi passi dal movimento del tuo WHOOP, calibrato sul conteggio dei passi del tuo telefono. È una stima, non un contapassi, un WHOOP 4.0 non trasmette i passi."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP 会根据你 WHOOP 的运动来估算步数，并以你手机的步数进行校准。这是一个估算值，而非计步器，WHOOP 4.0 不传输步数。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP 會根據你 WHOOP 的運動來估算步數，並以你手機的步數進行校準。這是一個估算值，而非計步器，WHOOP 4.0 不傳輸步數。"
          }
        }
      }
    },
    "NOOP gives you three daily scores (Charge, Effort and Rest), each on a 0–100 scale. They're built from your strap's raw signals using published, peer-reviewed sport science, and computed entirely on your device. They are NOT WHOOP's scores: we don't have WHOOP's private algorithms and don't pretend to. They aim at the same three questions using open science, so they'll usually track WHOOP's in direction, but won't match number-for-number. And that's the point.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP gibt dir drei Tageswerte (Erholung, Belastung und Schlaf), jeweils auf einer Skala von 0–100. Sie entstehen aus den Rohsignalen deines Straps mit veröffentlichter, begutachteter Sportwissenschaft und werden vollständig auf deinem Gerät berechnet. Es sind NICHT WHOOPs Werte: Wir haben WHOOPs private Algorithmen nicht und tun auch nicht so. Sie zielen mit offener Wissenschaft auf dieselben drei Fragen, folgen WHOOPs Werten also meist in der Richtung, stimmen aber nicht Zahl für Zahl überein. Und genau das ist der Punkt."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP te da tres puntuaciones diarias (Carga, Esfuerzo y Descanso), cada una en una escala de 0 a 100. Se construyen a partir de las señales en bruto de tu pulsera usando ciencia del deporte publicada y revisada por pares, y se calculan completamente en tu dispositivo. NO son las puntuaciones de WHOOP: no tenemos los algoritmos privados de WHOOP y no pretendemos tenerlos. Apuntan a las mismas tres preguntas usando ciencia abierta, así que normalmente seguirán la dirección de las de WHOOP, pero no coincidirán número a número. Y esa es la idea."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP ti offre tre punteggi giornalieri, carica, sforzo e riposo, ciascuno su una scala da 0 a 100. Sono costruiti a partire dai segnali grezzi della tua fascia usando scienza dello sport pubblicata e sottoposta a revisione paritaria, e calcolati interamente sul tuo dispositivo. NON sono i punteggi di WHOOP: non disponiamo degli algoritmi privati di WHOOP e non fingiamo di averli. Puntano alle stesse tre domande usando scienza aperta, quindi di solito seguiranno quelli di WHOOP come direzione, ma non corrisponderanno numero per numero, ed è proprio questo il punto."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP 为你提供三个每日评分，能量、消耗和休息，每个都采用 0–100 的量表。它们根据你手环的原始信号，运用已发表的、经同行评审的运动科学构建，并完全在你的设备上计算。它们不是 WHOOP 的评分：我们没有 WHOOP 的私有算法，也不假装拥有。它们运用开放科学瞄准同样的三个问题，因此通常在方向上会与 WHOOP 的一致，但不会数字对数字地吻合，而这正是重点所在。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP 為你提供三個每日評分，能量、消耗和休息，每個都採用 0–100 的量表。它們根據你手環的原始訊號，運用已發表的、經同行評審的運動科學構建，並完全在你的裝置上計算。它們不是 WHOOP 的評分：我們沒有 WHOOP 的私有演算法，也不假裝擁有。它們運用開放科學瞄準同樣的三個問題，因此通常在方向上會與 WHOOP 的一致，但不會數字對數字地吻合，而這正是重點所在。"
          }
        }
      }
    },
    "NOOP is a personal, open project: not the WHOOP app, and not affiliated with WHOOP. It reads a strap you own, on your own device. Treat it as a capable work-in-progress rather than a finished product.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP ist ein persönliches, offenes Projekt: nicht die WHOOP-App und nicht mit WHOOP verbunden. Es liest einen Strap, der dir gehört, auf deinem eigenen Gerät. Betrachte es als fähiges Work-in-Progress, nicht als fertiges Produkt."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP es un proyecto personal y abierto: no es la app de WHOOP ni está afiliado a WHOOP. Lee una pulsera que es tuya, en tu propio dispositivo. Trátalo como un trabajo en progreso capaz, más que como un producto terminado."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP è un progetto personale e aperto: non è l'app WHOOP e non è affiliato a WHOOP. Legge una fascia di tua proprietà, sul tuo dispositivo. Consideralo un lavoro in corso capace, più che un prodotto finito."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP 是一个个人开源项目：不是 WHOOP 应用，也与 WHOOP 无关。它在你自己的设备上读取你拥有的手环。请把它当作一个能干的进行中项目，而非成品。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP 是一個個人開放專案：它不是 WHOOP App，也與 WHOOP 沒有任何關聯。它在你自己的裝置上讀取你擁有的手環。請把它當作一個有實力但仍在進行中的作品，而非成品。"
          }
        }
      }
    },
    "NOOP is an unofficial project: not affiliated with, endorsed by, or sponsored by WHOOP, Inc. \"WHOOP\" is their trademark, used only to name the hardware NOOP works with.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP ist ein inoffizielles Projekt: nicht mit WHOOP, Inc. verbunden, nicht von ihr unterstützt oder gesponsert. „WHOOP“ ist deren Marke und wird nur verwendet, um die Hardware zu benennen, mit der NOOP arbeitet."
          }
        }
      }
    },
    "NOOP is free and provided \"as is\", with no warranty. Liability is limited to the maximum extent the law that applies to you allows, and nothing here removes protections your local law won't let us remove.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP ist kostenlos und wird „wie besehen“ bereitgestellt, ohne Gewährleistung. Die Haftung ist im maximal zulässigen Umfang des für dich geltenden Rechts begrenzt, und nichts hier nimmt dir Schutz, den dein lokales Recht uns nicht zu nehmen erlaubt."
          }
        }
      }
    },
    "NOOP is not a medical device. It is for informational and personal-insight purposes only and is not intended to diagnose, treat, cure or prevent any condition. Talk to a clinician for medical advice.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP ist kein medizinisches Gerät. Es dient nur zu Informations- und persönlichen Erkenntniszwecken und ist nicht dazu bestimmt, Erkrankungen zu diagnostizieren, zu behandeln, zu heilen oder zu verhindern. Wende dich für medizinischen Rat an eine Fachperson."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP is not a medical device. It is for informational and personal-insight purposes only and is not intended to diagnose, treat, cure or prevent any condition. Talk to a clinician for medical advice."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP no es un dispositivo médico. Es solo para fines informativos y de conocimiento personal, y no está destinado a diagnosticar, tratar, curar ni prevenir ninguna afección. Consulta a un profesional médico para obtener consejo médico."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP n'est pas un dispositif médical. Il est destiné uniquement à des fins d'information et d'introspection personnelle et n'est pas conçu pour diagnostiquer, traiter, guérir ou prévenir une condition. Consultez un clinicien pour des conseils médicaux."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP non è un dispositivo medico. Ha solo finalità informative e di conoscenza personale e non è destinato a diagnosticare, trattare, curare o prevenire alcuna condizione. Per consigli medici rivolgiti a un medico."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP не является медицинским устройством. Он предназначен только для информации и личного анализа и не предназначен для диагностики, лечения или профилактики каких-либо состояний. За медицинской консультацией обращайтесь к врачу."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP 不是医疗设备。它仅用于提供信息和个人洞察，并非旨在诊断、治疗、治愈或预防任何疾病。如需医疗建议，请咨询临床医生。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP 不是醫療裝置。它僅用於提供資訊和個人洞察，並非旨在診斷、治療、治癒或預防任何疾病。如需醫療建議，請諮詢臨床醫生。"
          }
        }
      }
    },
    "NOOP is opening your on-device data. Your paired bands will appear here in a moment.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP öffnet deine Daten auf dem Gerät. Deine gekoppelten Bänder erscheinen hier gleich."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP está abriendo tus datos en el dispositivo. Tus bandas emparejadas aparecerán aquí en un momento."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP sta aprendo i tuoi dati sul dispositivo. Le tue fasce abbinate appariranno qui tra un momento."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP 正在打开你设备上的数据。你已配对的手环稍后会出现在这里。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP 正在打開你裝置上的資料。你已配對的手環稍後會出現在這裡。"
          }
        }
      }
    },
    "NOOP looks for known notification apps on %@: Mail, Outlook, WhatsApp, Teams, Messages, Slack and similar. Install one and it'll appear here automatically.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP sucht nach bekannten Benachrichtigungs-Apps auf %@: Mail, Outlook, WhatsApp, Teams, Nachrichten, Slack und ähnliche. Installiere eine, und sie erscheint hier automatisch."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP busca apps de notificaciones conocidas en %@: Mail, Outlook, WhatsApp, Teams, Mensajes, Slack y similares. Instala una y aparecerá aquí automáticamente."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP cerca le app di notifica conosciute su %@: Mail, Outlook, WhatsApp, Teams, Messaggi, Slack e simili. Installane una e apparirà qui automaticamente."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP 会在 %@ 上查找已知的通知应用：邮件、Outlook、WhatsApp、Teams、信息、Slack 等。安装一个后它会自动出现在这里。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP 會在 %@ 上尋找已知的通知 App：Mail、Outlook、WhatsApp、Teams、訊息、Slack 等等。安裝其中一個，它就會自動出現在這裡。"
          }
        }
      }
    },
    "NOOP looks for machines that broadcast the standard Bluetooth Fitness Machine service.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP sucht nach Geräten, die den Standard-Bluetooth-Fitnessgeräte-Dienst (FTMS) senden."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP busca máquinas que emitan el servicio estándar Bluetooth Fitness Machine."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP cerca macchine che trasmettono il servizio standard Bluetooth Fitness Machine."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP 会查找广播标准 Bluetooth 健身器材服务的设备。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP 會尋找廣播標準 Bluetooth 健身器材服務的機器。"
          }
        }
      }
    },
    "NOOP never decides whether a value is \"normal,\" \"high,\" or \"low.\" Any reference range shown is exactly what you typed from your own report.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP entscheidet nie, ob ein Wert „normal“, „hoch“ oder „niedrig“ ist. Jeder angezeigte Referenzbereich ist genau das, was du aus deinem eigenen Befund eingetippt hast."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP nunca decide si un valor es \"normal\", \"alto\" o \"bajo\". Cualquier rango de referencia mostrado es exactamente lo que escribiste de tu propio informe."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP non decide mai se un valore è \"normale\", \"alto\" o \"basso\". Ogni range di riferimento mostrato è esattamente quello che hai digitato dal tuo referto."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP 从不判断数值是「正常」「偏高」还是「偏低」。显示的任何参考范围都完全来自你从自己报告中输入的内容。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP 絕不判定數值是「正常」、「偏高」還是「偏低」。顯示的任何參考範圍都完全來自你從自己報告中輸入的內容。"
          }
        }
      }
    },
    "NOOP never fills this in. It only shows back exactly what you type from your own report.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP füllt das nie aus. Es zeigt nur genau das zurück, was du aus deinem eigenen Befund eintippst."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP nunca rellena esto. Solo muestra exactamente lo que escribes de tu propio informe."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP non compila mai questo campo, mostra solo esattamente ciò che digiti dal tuo stesso referto."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP 绝不会填写此项，它只会原样显示你根据自己的报告所输入的内容。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP 絕不會填寫此項，它只會原樣顯示你根據自己的報告所輸入的內容。"
          }
        }
      }
    },
    "NOOP never makes up a number. When it can't compute one honestly it tells you what's missing and what to do, rather than showing a fake value.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP erfindet nie eine Zahl. Wenn es eine nicht ehrlich berechnen kann, sagt es dir, was fehlt und was zu tun ist, statt einen falschen Wert zu zeigen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP nunca inventa un número. Cuando no puede calcularlo honestamente, te dice qué falta y qué hacer, en lugar de mostrar un valor falso."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP non inventa mai un numero. Quando non può calcolarne uno in modo onesto ti dice cosa manca e cosa fare, invece di mostrare un valore falso."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP 绝不编造数字。当它无法诚实地计算出一个数字时，它会告诉你缺少什么以及该怎么做，而不是显示一个虚假的数值。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP 絕不編造數字。當它無法誠實地計算出一個數字時，它會告訴你缺少什麼以及該怎麼做，而不是顯示一個虛假的數值。"
          }
        }
      }
    },
    "NOOP never shows you a number it had to make up. If a score isn't ready, it tells you why and what to do next. Everything here runs on your device, from your strap.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP zeigt dir nie eine Zahl, die es erfinden musste. Wenn ein Wert nicht bereit ist, sagt es dir, warum und was als Nächstes zu tun ist. Alles hier läuft auf deinem Gerät, von deinem Strap."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP nunca te muestra un número que haya tenido que inventar. Si una puntuación no está lista, te dice por qué y qué hacer a continuación. Todo aquí se ejecuta en tu dispositivo, desde tu pulsera."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP non ti mostra mai un numero che ha dovuto inventare. Se un punteggio non è pronto, ti dice perché e cosa fare dopo. Tutto qui funziona sul tuo dispositivo, dalla tua fascia."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP 绝不会向你显示它不得不编造的数字。如果某个评分尚未就绪，它会告诉你原因以及下一步该怎么做。这里的一切都在你的设备上运行，源自你的手环。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP 絕不會向你顯示它不得不編造的數字。如果某個評分尚未就緒，它會告訴你原因以及下一步該怎麼做。這裡的一切都在你的裝置上運行，源自你的手環。"
          }
        }
      }
    },
    "NOOP pairs directly with your WHOOP over Bluetooth, no WHOOP app, no cloud.": {
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP koppelt sich direkt über Bluetooth mit deinem WHOOP, keine WHOOP-App, keine Cloud."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP pairs directly with your WHOOP over Bluetooth, no WHOOP app, no cloud."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP se conecta directamente con tu WHOOP por Bluetooth: sin app de WHOOP, sin nube."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP se connecte directement à votre WHOOP via Bluetooth, sans app WHOOP, sans cloud."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP si abbina direttamente al tuo WHOOP via Bluetooth, niente app WHOOP, niente cloud."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP подключается к вашему WHOOP напрямую по Bluetooth, без приложения WHOOP и без облака."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP 通过蓝牙直接与你的 WHOOP 配对，，无需 WHOOP 应用，无需云端。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP 透過藍牙直接與你的 WHOOP 配對，，無需 WHOOP 應用程式，無需雲端。"
          }
        }
      }
    },
    "NOOP pairs directly with your WHOOP over Bluetooth: no WHOOP app, no cloud.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP koppelt sich direkt über Bluetooth mit deinem WHOOP: keine WHOOP-App, keine Cloud."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP se empareja directamente con tu WHOOP por Bluetooth: sin app de WHOOP, sin nube."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP si abbina direttamente al tuo WHOOP via Bluetooth, niente app WHOOP, niente cloud."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP 通过蓝牙直接与你的 WHOOP 配对，无需 WHOOP 应用，无需云端。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP 透過藍牙直接與你的 WHOOP 配對，無需 WHOOP 應用程式，無需雲端。"
          }
        }
      }
    },
    "NOOP picks the best-sourced number and shows you where each came from. It's for wellness and curiosity. It doesn't diagnose or replace medical advice.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP wählt die Zahl mit der besten Quelle und zeigt dir, woher jede stammt. Es ist für Wellness und Neugier. Es diagnostiziert nicht und ersetzt keinen medizinischen Rat."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP elige el número con mejor fuente y te muestra de dónde vino cada uno. Es para bienestar y curiosidad. No diagnostica ni reemplaza el consejo médico."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP sceglie il numero dalla fonte migliore e ti mostra da dove proviene ciascuno. È per il benessere e la curiosità, non diagnostica né sostituisce il parere medico."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP 会挑选来源最佳的数字，并向你显示每一个的来处。它用于健康和求知，它不诊断，也不替代医疗建议。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP 會挑選來源最佳的數字，並向你顯示每一個的來處。它用於健康和求知，它不診斷，也不替代醫療建議。"
          }
        }
      }
    },
    "NOOP picks your main sleep as your longest real block, and (once it has learned your usual hours) the one nearest your normal sleep time. Everything else that day is a nap. You can always edit bed and wake times.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP wählt als Hauptschlaf deinen längsten echten Block und (sobald es deine üblichen Zeiten gelernt hat) den, der deiner normalen Schlafenszeit am nächsten liegt. Alles andere an dem Tag ist ein Nickerchen. Bett- und Aufwachzeiten kannst du immer bearbeiten."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP elige tu sueño principal como tu bloque real más largo y (una vez que ha aprendido tus horarios habituales) el más cercano a tu hora normal de dormir. Todo lo demás ese día es una siesta. Siempre puedes editar las horas de acostarte y despertar."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP sceglie come sonno principale il tuo blocco reale più lungo e (una volta imparati i tuoi orari abituali) quello più vicino al tuo normale orario di sonno. Tutto il resto di quel giorno è un pisolino. Puoi sempre modificare gli orari di addormentamento e risveglio."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP 把你最长的真实睡眠段选为主睡眠，并且（在学会你的日常作息后）优先选最接近你平时睡觉时间的那段。当天其余的都算小睡。你随时可以编辑入睡和起床时间。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP 會把你最長的真實睡眠時段選為主要睡眠，而在學會你的作息之後，會選最接近你平常入睡時間的那段。當天其餘的都算小睡。你隨時可以編輯就寢與起床時間。"
          }
        }
      }
    },
    "NOOP reads live heart rate on bands that don't require pairing. Newer bands need an auth handshake we can't do yet.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP liest Live-Herzfrequenz auf Bändern, die keine Kopplung erfordern. Neuere Bänder brauchen einen Auth-Handshake, den wir noch nicht können."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP lee la frecuencia cardíaca en vivo en bandas que no requieren emparejamiento. Las bandas más nuevas necesitan un handshake de autenticación que aún no podemos hacer."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP legge la frequenza cardiaca in tempo reale sulle band che non richiedono l'abbinamento. Le band più recenti richiedono un handshake di autenticazione che non sappiamo ancora fare."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP 可在无需配对的手环上读取实时心率。较新的手环需要一种我们暂时无法完成的认证握手。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP 可以在不需配對的手環上讀取即時心率。較新的手環需要我們目前還做不到的驗證交握。"
          }
        }
      }
    },
    "NOOP reads live heart rate when the band exposes it. Some bands need a pairing we can't do yet. If so, we'll say so honestly.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP liest Live-Herzfrequenz, wenn das Band sie freigibt. Manche Bänder brauchen eine Kopplung, die wir noch nicht können. Falls ja, sagen wir es ehrlich."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP lee la frecuencia cardíaca en vivo cuando la banda la expone. Algunas bandas necesitan un emparejamiento que aún no podemos hacer. Si es el caso, te lo diremos con honestidad."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP legge la frequenza cardiaca in tempo reale quando la band la espone. Alcune band richiedono un abbinamento che non sappiamo ancora fare. In tal caso, te lo diremo onestamente."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "只要手环开放实时心率，NOOP 就能读取。有些手环需要我们暂时无法完成的配对。如果是这样，我们会如实告诉你。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "只要手環有開放，NOOP 就能讀取即時心率。有些手環需要我們目前還做不到的配對。如果是這樣，我們會誠實告訴你。"
          }
        }
      }
    },
    "NOOP reads your Apple Watch data through Apple Health, on your phone, nothing leaves the device. You choose exactly what to share.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP liest deine Apple-Watch-Daten über Apple Health, auf deinem Telefon, nichts verlässt das Gerät. Du wählst genau, was du teilst."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP lee los datos de tu Apple Watch a través de Apple Health, en tu teléfono; nada sale del dispositivo. Tú eliges exactamente qué compartir."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP legge i dati del tuo Apple Watch tramite Apple Health, sul tuo telefono, niente lascia il dispositivo. Scegli tu esattamente cosa condividere."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP 通过 Apple 健康在你的手机上读取你的 Apple Watch 数据，没有任何内容离开设备。你可以确切地选择要分享什么。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP 透過 Apple 健康在你的手機上讀取你的 Apple Watch 資料，沒有任何內容離開裝置。你可以確切地選擇要分享什麼。"
          }
        }
      }
    },
    "NOOP reads your heart rate, HRV, resting heart rate, sleep, steps, energy and VO₂ max from Apple Health to compute your scores. It all stays on this iPhone, and you pick exactly what to share on the next screen.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP liest deine Herzfrequenz, HRV, Ruheherzfrequenz, deinen Schlaf, deine Schritte, Energie und VO₂max aus Apple Health, um deine Werte zu berechnen. Alles bleibt auf diesem iPhone, und du wählst im nächsten Schritt genau, was du teilst."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP lee tu frecuencia cardíaca, VFC, frecuencia cardíaca en reposo, sueño, pasos, energía y VO₂ máx desde Apple Health para calcular tus puntuaciones. Todo permanece en este iPhone, y en la siguiente pantalla eliges exactamente qué compartir."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP legge la tua frequenza cardiaca, l'HRV, la frequenza cardiaca a riposo, il sonno, i passi, l'energia e il VO₂ max da Apple Health per calcolare i tuoi punteggi. Resta tutto su questo iPhone, e scegli tu esattamente cosa condividere nella schermata successiva."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP 从 Apple 健康读取你的心率、HRV、静息心率、睡眠、步数、能量和最大摄氧量来计算你的评分。一切都留在这台 iPhone 上，你可以在下一屏确切地选择要分享什么。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP 從 Apple 健康讀取你的心率、HRV、靜息心率、睡眠、步數、能量和最大攝氧量來計算你的評分。一切都留在這台 iPhone 上，你可以在下一畫面確切地選擇要分享什麼。"
          }
        }
      }
    },
    "NOOP scores your charge, effort and rest itself: on-device, no cloud.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP berechnet deine Erholung, Belastung und Schlaf selbst: auf dem Gerät, keine Cloud."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP calcula tu carga, esfuerzo y descanso por sí mismo: en el dispositivo, sin nube."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP calcola da sé la tua carica, lo sforzo e il riposo, sul dispositivo, niente cloud."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP 自行计算你的能量、消耗和休息评分，在设备本地，无需云端。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP 自行計算你的能量、消耗和休息評分，在裝置本地，無需雲端。"
          }
        }
      }
    },
    "NOOP scores your recovery, strain and sleep itself, on-device, no cloud.": {
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP berechnet deine Erholung, Belastung und deinen Schlaf selbst, auf dem Gerät, ohne Cloud."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP scores your recovery, strain and sleep itself, on-device, no cloud."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP calcula tu recuperación, esfuerzo y sueño por sí mismo: en el dispositivo, sin nube."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP calcule lui-même votre récupération, strain et sommeil, sur l'appareil, sans cloud."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP calcola da sé il tuo recupero, carico e sonno, sul dispositivo, senza cloud."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP сам рассчитывает восстановление, нагрузку и показатели сна, прямо на устройстве, без облака."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP 自行计算你的恢复、强度和睡眠评分，，在设备本地，无需云端。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP 自行計算你的恢復、強度和睡眠評分，，在裝置本地，無需雲端。"
          }
        }
      }
    },
    "NOOP shows the %@ reading because it %@ for this metric: a higher-trust source here, not a verdict that the others are wrong.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP zeigt den %1$@-Messwert, weil er für diese Metrik %2$@: eine vertrauenswürdigere Quelle hier, kein Urteil, dass die anderen falsch liegen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "NOOP shows the %1$@ reading because it %2$@ for this metric, a higher-trust source here, not a verdict that the others are wrong."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP muestra la lectura de %@ porque %@ para esta métrica: una fuente de mayor confianza en este caso, no un veredicto de que las demás estén mal."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP mostra la lettura di %1$@ perché %2$@ per questa metrica, una fonte più affidabile in questo caso, non un verdetto che le altre siano sbagliate."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP 显示 %1$@ 的读数，因为对于此项指标它 %2$@，在这里是一个更可信的来源，而非判定其他来源是错的。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP 顯示 %1$@ 的讀數，因為對於此項指標它 %2$@，在這裡是一個更可信的來源，而非判定其他來源是錯的。"
          }
        }
      }
    },
    "NOOP stores and lines up the numbers you enter yourself. It does not test you, read your results, give medical advice, or diagnose anything.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP speichert die Zahlen, die du selbst eingibst, und stellt sie nebeneinander. Es testet dich nicht, liest keine Befunde, gibt keinen medizinischen Rat und diagnostiziert nichts."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP almacena y organiza los números que introduces tú mismo. No te hace pruebas, no lee tus resultados, no da consejos médicos ni diagnostica nada."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP memorizza e mette in fila i numeri che inserisci tu stesso. Non ti fa esami, non legge i tuoi risultati, non dà consigli medici e non diagnostica nulla."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP 只存储并整理你自己输入的数字。它不做检测、不解读结果、不提供医疗建议，也不做任何诊断。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP 只儲存並整理你自己輸入的數字。它不會為你檢測、解讀你的結果、提供醫療建議或做任何診斷。"
          }
        }
      }
    },
    "NOOP stores this key only on this device, in the same place it stores your paired bands.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP speichert diesen Schlüssel nur auf diesem Gerät, am selben Ort wie deine gekoppelten Bänder."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP guarda esta clave solo en este dispositivo, en el mismo lugar donde guarda tus bandas emparejadas."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP memorizza questa chiave solo su questo dispositivo, nello stesso posto in cui memorizza le tue fasce abbinate."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP 只将此密钥存储在这台设备上，与它存储你已配对手环的位置相同。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP 只將此金鑰儲存在這台裝置上，與它儲存你已配對手環的位置相同。"
          }
        }
      }
    },
    "NOOP talks to your strap directly over Bluetooth Low Energy. There's no server in the middle. The connection is local, and so is every reading it pulls in.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP spricht direkt über Bluetooth Low Energy mit deinem Strap. Es gibt keinen Server dazwischen. Die Verbindung ist lokal, und das gilt auch für jeden Messwert, den sie hereinholt."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP se comunica con tu pulsera directamente por Bluetooth Low Energy. No hay ningún servidor de por medio. La conexión es local, igual que cada lectura que recibe."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP parla con la tua fascia direttamente via Bluetooth Low Energy. Non c'è nessun server in mezzo. La connessione è locale, e lo è anche ogni lettura che raccoglie."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP 通过低功耗 Bluetooth 直接与你的手环通信。中间没有服务器。连接是本地的，读取到的每条数据也是。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP 透過低功耗 Bluetooth 直接與你的手環通信。中間沒有任何伺服器。連接是本機的，讀進來的每一筆資料也是。"
          }
        }
      }
    },
    "NOOP talks to your strap's firmware over an unofficial, independently-mapped protocol. There is a residual risk to the device, its data, and its connection to official services. You assume that risk.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP spricht mit der Firmware deines Straps über ein inoffizielles, unabhängig rekonstruiertes Protokoll. Es bleibt ein Restrisiko für das Gerät, seine Daten und seine Verbindung zu offiziellen Diensten. Dieses Risiko übernimmst du."
          }
        }
      }
    },
    "NOOP taps your strap so an alert lands on your wrist instead of your screen. No need to reach for it. Everything stays on %@.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP tippt deinen Strap an, damit ein Hinweis auf deinem Handgelenk landet statt auf deinem Bildschirm. Kein Griff zum Telefon nötig. Alles bleibt auf %@."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP hace vibrar tu pulsera para que la alerta llegue a tu muñeca en lugar de a tu pantalla. No hace falta coger el teléfono. Todo permanece en %@."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP tocca la tua fascia così l'avviso arriva al polso invece che sullo schermo. Non serve prendere il telefono. Tutto resta su %@."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP 会轻拍你的手环，把提醒送到手腕而不是屏幕上。不用伸手拿手机。一切都留在 %@ 上。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP 會輕拍你的手環，讓提醒落在手腕上而不是螢幕上。不必伸手拿手機。一切都留在 %@ 上。"
          }
        }
      }
    },
    "NOOP will install its own key on the ring and become its owner. The Oura app will no longer control this ring. This is intended and it cannot be undone from NOOP.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP installiert seinen eigenen Schlüssel auf dem Ring und wird sein Besitzer. Die Oura-App steuert diesen Ring dann nicht mehr. Das ist beabsichtigt und kann von NOOP aus nicht rückgängig gemacht werden."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP instalará su propia clave en el anillo y se convertirá en su propietario. La app de Oura ya no controlará este anillo. Esto es intencional y no se puede deshacer desde NOOP."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP installerà la propria chiave sull'anello e ne diventerà il proprietario. L'app Oura non controllerà più questo anello. È voluto e non può essere annullato da NOOP."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP 会在戒指上安装自己的密钥并成为其持有者。Oura 应用将不再控制这枚戒指。这是有意为之，且无法从 NOOP 撤销。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP 會在戒指上安裝自己的金鑰並成為其持有者。Oura 應用程式將不再控制這枚戒指。這是有意為之，且無法從 NOOP 撤銷。"
          }
        }
      }
    },
    "NOOP will look for it nearby.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP sucht ihn in der Nähe."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP lo buscará cerca."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP lo cercherà nelle vicinanze."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP 会在附近查找它。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP 會在附近尋找它。"
          }
        }
      }
    },
    "NOOP will re-learn your baseline from tonight's data onward. Your history is kept, and it takes a few nights to settle.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP lernt deine Basislinie ab den Daten von heute Nacht neu. Dein Verlauf bleibt erhalten, und es braucht ein paar Nächte, bis es sich einpendelt."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP volverá a aprender tu línea base a partir de los datos de esta noche. Tu historial se conserva, y tarda unas cuantas noches en estabilizarse."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP riapprenderà la tua linea di base dai dati di stanotte in poi. La tua cronologia viene conservata, e servono alcune notti per assestarsi."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP 会从今晚的数据开始重新学习你的基线。历史记录会保留，稳定下来需要几个晚上。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP 會從今晚的資料開始重新學習你的基線。你的歷史記錄會保留，需要幾個晚上才能穩定下來。"
          }
        }
      }
    },
    "NOOP's own Charge, Effort and Rest, computed on your device from published methods.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOPs eigene Erholung, Belastung und Schlaf, berechnet auf deinem Gerät nach veröffentlichten Methoden."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los propios Carga, Esfuerzo y Descanso de NOOP, calculados en tu dispositivo a partir de métodos publicados."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Carica, Sforzo e Riposo calcolati da NOOP sul tuo dispositivo a partire da metodi pubblicati."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP 自己的能量、消耗和休息，基于公开方法在你的设备上计算。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOP 自己的能量、消耗與休息，依據公開發表的方法在你的裝置上計算。"
          }
        }
      }
    },
    "NOOP's primary, fully-supported band": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "NOOPs primäres, voll unterstütztes Band"
          }

    "Train by feel. The strap buzzes so you don't have to watch a screen.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Trainiere nach Gefühl. Der Strap vibriert, damit du nicht auf einen Bildschirm schauen musst."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Entrena por sensaciones. La pulsera vibra para que no tengas que mirar una pantalla."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Allenati a sensazione. La fascia vibra così non devi guardare uno schermo."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "凭感觉训练。手环会震动提醒，你无需盯着屏幕。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "憑感覺訓練。手環會震動，你不必盯著螢幕。"
          }
        }
      }
    },

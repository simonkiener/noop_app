    "See how Charge, Effort and Rest are calculated, and how they differ from WHOOP.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sieh, wie Erholung, Belastung und Schlaf berechnet werden und wie sie sich von WHOOP unterscheiden."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mira cómo se calculan la Carga, el Esfuerzo y el Descanso, y en qué se diferencian de WHOOP."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Scopri come vengono calcolati carica, sforzo e riposo, e in cosa differiscono da WHOOP."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "了解能量、消耗和休息如何计算，以及它们与 WHOOP 的区别。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "了解能量、消耗和休息如何計算，以及它們與 WHOOP 的區別。"
          }
        }
      }
    },
    "See recovery, beautifully": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",

    "Deep data (R22) needs an iPhone or Android. A Mac can't form the encrypted bond a 5/MG requires.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Tiefendaten (R22) brauchen ein iPhone oder Android. Ein Mac kann die verschlüsselte Kopplung, die ein 5/MG verlangt, nicht aufbauen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los datos profundos (R22) necesitan un iPhone o Android. Una Mac no puede formar el vínculo cifrado que requiere una 5/MG."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I dati approfonditi (R22) richiedono un iPhone o un Android. Un Mac non può stabilire l'abbinamento cifrato richiesto da un 5/MG."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "深度数据（R22）需要 iPhone 或 Android。Mac 无法建立 5/MG 所需的加密配对。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "深層資料（R22）需要 iPhone 或 Android。Mac 無法建立 5/MG 所需的加密綁定。"
          }
        }
      }
    },

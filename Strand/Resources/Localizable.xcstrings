    "Lifting": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Krafttraining"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Pesas"
          }

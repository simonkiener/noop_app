    "%@ No clear relationship. They move largely independently.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ Kein klarer Zusammenhang. Sie bewegen sich weitgehend unabhängig."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ Sin relación clara. Se mueven de forma mayormente independiente."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ Nessuna relazione chiara. Si muovono in gran parte in modo indipendente."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ 没有明显关系。两者基本各自独立变化。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ 沒有明顯關聯。兩者大致各自獨立變化。"
          }
        }
      }
    },
    "%@ When %@ rises, %@ tends to fall, a %@ %@ link.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ Wenn %2$@ steigt, fällt %3$@ tendenziell (Zusammenhang: %4$@, %5$@)."
          }
        },
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "%1$@ When %2$@ rises, %3$@ tends to fall, a %4$@ %5$@ link."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ Cuando %@ sube, %@ tiende a bajar, un vínculo %@ %@."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ Quando %@ sale, %@ tende a scendere, un legame %@ %@."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ 当 %@ 上升时，%@ 往往下降，属于 %@ %@ 关联。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ 當 %@ 上升時，%@ 傾向下降，屬 %@ 的 %@ 關聯。"
          }
        }
      }
    },

    "Stop caffeine after about %@ to keep most of it cleared by %@.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Hör etwa ab %1$@ mit Koffein auf, damit das meiste bis %2$@ abgebaut ist."
          }
        },
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "Stop caffeine after about %1$@ to keep most of it cleared by %2$@."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Deja la cafeína después de aproximadamente las %@ para tener la mayor parte eliminada hacia las %@."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Smetti con la caffeina dopo circa %1$@ per smaltirne gran parte entro %2$@."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在大约 %1$@ 之后停止摄入咖啡因，以便在 %2$@ 前将其大部分代谢掉。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在大約 %1$@ 之後停止攝入咖啡因，以便在 %2$@ 前將其大部分代謝掉。"
          }
        }
      }
    },

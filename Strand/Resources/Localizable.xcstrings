            "state": "translated",
            "value": "Quale fascia stai associando?"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你正在配对哪一个手环？"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "你正在配對哪一個手環？"
          }
        }
      }
    },

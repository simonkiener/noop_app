    "Powers Effort now; Charge and Rest once enough nights and decode are confirmed": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Speist jetzt Belastung; Erholung und Schlaf, sobald genug Nächte und die Dekodierung bestätigt sind"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Alimenta Esfuerzo ahora; Carga y Descanso cuando se confirmen suficientes noches y la decodificación"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Alimenta subito Sforzo; Carica e Riposo una volta confermate abbastanza notti e la decodifica"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "现在驱动消耗；待累积足够的夜晚并确认解码后，将驱动能量和休息"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "目前為消耗提供資料；累積足夠夜晚並確認解碼後，也會支援能量和休息"
          }
        }
      }
    },
    "Powers Rest, Effort, Fitness Age and steps, plus Charge once recovery calibrates": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Speist Schlaf, Belastung, Fitnessalter und Schritte, plus Erholung, sobald die Erholung kalibriert ist"
          }
        },
        "es": {
          "stringUnit": {

        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Interrogate what affects what."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Investiga qué afecta a qué."
          }
        },
        "fr": {

          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "阅读完整的实验手记说明"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "閱讀完整的實驗手記說明"
          }
        }
      }
    },
    "Read the full note": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Den vollständigen Hinweis lesen"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Leer la nota completa"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Leggi la nota completa"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "阅读完整说明"
          }
        },
        "zh-Hant": {

    "Autonomic rigidity from your heart-rate rhythm. Higher means a more rigid, stressed rhythm.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Autonome Rigidität aus deinem Herzrhythmus. Höher bedeutet einen starreren, gestressteren Rhythmus."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Rigidez autonómica según el ritmo de tu frecuencia cardíaca. Cuanto más alto, más rígido y estresado es el ritmo."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Rigidità autonomica dal ritmo della tua frequenza cardiaca. Più alto significa un ritmo più rigido e stressato."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "由心率节律得出的自主神经僵硬度。数值越高，节律越僵硬、越紧张。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "從你的心率節律得出的自律神經僵硬度。數值越高，代表節律越僵硬、越有壓力。"
          }
        }
      }
    },

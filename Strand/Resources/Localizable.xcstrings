          }
        }
      }
    },
    "You'll be reminded around %@.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Du wirst gegen %@ erinnert."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se te recordará alrededor de las %@."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Riceverai un promemoria intorno alle %@."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你会在 %@ 左右收到提醒。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "你會在 %@ 左右收到提醒。"
          }
        }
      }
    },
    "You'll likely wake around %lld ± %lld Charge if you sleep about %@ tonight.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Du wachst voraussichtlich mit etwa %1$lld ± %2$lld Erholung auf, wenn du heute Nacht ungefähr %3$@ schläfst."
          }
        },
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "You'll likely wake around %1$lld ± %2$lld Recovery if you sleep about %3$@ tonight."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Probablemente despertarás con alrededor de %lld ± %lld de Carga si duermes unas %@ esta noche."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Probabilmente ti sveglierai intorno a %1$lld ± %2$lld di carica se dormi circa %3$@ stanotte."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "如果你今晚睡大约 %3$@，你醒来时的能量可能在 %1$lld ± %2$lld 左右。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "如果你今晚睡大約 %3$@，你醒來時的能量可能在 %1$lld ± %2$lld 左右。"
          }
        }
      }
    },
    "You're all caught up.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Du bist auf dem neuesten Stand."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Estás al día."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Sei in pari con tutto."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你已全部看完。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "你已全部看完。"
          }
        }
      }
    },
    "You're carrying about %@ of surplus over %@. You've slept past your need on balance. Nicely ahead.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Du trägst etwa %1$@ Überschuss über %2$@. Unterm Strich hast du über deinen Bedarf geschlafen. Schön im Plus."
          }
        },
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "You're carrying about %1$@ of surplus over %2$@. You've slept past your need on balance. Nicely ahead."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Llevas alrededor de %@ de superávit en %@. En balance, has dormido más de lo que necesitas. Vas bien adelantado."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Hai circa %@ di surplus su %@. Nel complesso hai dormito più del tuo fabbisogno. Sei ben in vantaggio."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你累积了约 %@ 的盈余，时间跨度为%@。总体上你的睡眠超过了所需。领先得不错。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "你累積了約 %@ 的睡眠盈餘（期間：%@）。整體而言你睡得超過所需，狀態領先。"
          }
        }
      }
    },
    "You're connected.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Du bist verbunden."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You're connected."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Estás conectado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "You're connected."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Sei collegato."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вы подключены."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你已连接。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "你已連接。"
          }
        }
      }
    },
    "You're connected. NOOP is reading your Apple Watch data now. Your Charge score will spend its first week or so calibrating, then settle in.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Du bist verbunden. NOOP liest jetzt deine Apple-Watch-Daten. Dein Ladungswert kalibriert etwa in der ersten Woche, dann pendelt er sich ein."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Estás conectado. NOOP ya está leyendo los datos de tu Apple Watch. Tu puntuación de Carga pasará más o menos su primera semana calibrándose y luego se estabilizará."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Sei connesso. NOOP sta leggendo ora i dati del tuo Apple Watch. Il tuo punteggio di carica passerà la prima settimana circa a calibrarsi, poi si stabilizzerà."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你已连接。NOOP 现在正在读取你的 Apple Watch 数据。你的能量评分将在最初一周左右进行校准，然后稳定下来。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "你已連接。NOOP 現在正在讀取你的 Apple Watch 資料。你的能量評分將在最初一週左右進行校準，然後穩定下來。"
          }
        }
      }
    },
    "You're in balance with your baseline, so moderate strain is well-judged": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Du bist im Gleichgewicht mit deiner Basislinie, moderate Belastung ist also gut gewählt"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Estás en equilibrio con tu línea base, así que un esfuerzo moderado es acertado"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Sei in equilibrio con la tua linea di base, quindi un carico moderato è una buona scelta"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你与基线保持平衡，适度的强度是明智之选"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "你與基線保持平衡，中等強度是明智的選擇"
          }
        }
      }
    },
    "You're on the latest (%@).": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Du bist auf dem neuesten Stand (%@)."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tienes la última versión (%@)."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Hai la versione più recente (%@)."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你已是最新版本（%@）。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "你已是最新版本（%@）。"
          }
        }
      }
    },
    "You're roughly on top of your sleep across %@. Slept minutes balance out against your need.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Über %@ bist du bei deinem Schlaf ungefähr im Soll. Geschlafene Minuten gleichen sich mit deinem Bedarf aus."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Vas más o menos al día con tu sueño en %@. Los minutos dormidos se equilibran con tu necesidad."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Sei più o meno in pari con il sonno su %@. I minuti dormiti si bilanciano con il tuo fabbisogno."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在%@内你的睡眠大致跟上了节奏。实际睡眠时长与所需基本持平。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在%@內你的睡眠大致跟上了需求，睡眠分鐘數與所需相抵。"
          }
        }
      }
    },
    "You're sitting around your typical autonomic baseline: moderate stress, a normal, balanced day.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Du liegst um deine typische autonome Basislinie: moderater Stress, ein normaler, ausgeglichener Tag."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Estás alrededor de tu línea base autonómica típica: estrés moderado, un día normal y equilibrado."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Sei intorno alla tua tipica linea di base autonomica: stress moderato, una giornata normale ed equilibrata."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你正处于典型的自主神经基线附近：压力适中，是正常、平衡的一天。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "你目前處於典型的自律神經基線附近：中等壓力，一個正常、平衡的日子。"
          }
        }
      }
    },
    "You've banked about %@ of sleep debt over %@. Surplus nights count back against it. An earlier night or two would clear it.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Du hast über %2$@ etwa %1$@ Schlafdefizit angesammelt. Überschuss-Nächte zählen dagegen. Ein oder zwei frühere Nächte würden es ausgleichen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "You've banked about %1$@ of sleep debt over %2$@. Surplus nights count back against it. An earlier night or two would clear it."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Has acumulado alrededor de %@ de deuda de sueño en %@. Las noches con superávit la reducen. Una o dos noches acostándote más temprano la eliminarían."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Hai accumulato circa %@ di debito di sonno su %@. Le notti in surplus lo riducono. Una o due serate anticipate lo azzererebbero."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你累积了约 %@ 的睡眠负债，时间跨度为%@。盈余的夜晚会抵消它。早睡一两晚就能还清。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "你累積了約 %@ 的睡眠負債（期間：%@）。有盈餘的夜晚會抵銷它。早睡一兩晚就能還清。"
          }
        }
      }
    },
    "You've been seated for about %lld min. Time to move.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Du sitzt seit etwa %lld Min. Zeit für Bewegung."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Llevas sentado unos %lld min. Hora de moverte."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Sei seduto da circa %lld min. È ora di muoversi."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你已经坐了约 %lld 分钟。该动一动了。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "你已經坐了大約 %lld 分鐘，該動一動了。"
          }
        }
      }
    },
    "Your Apple Watch as a device": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Deine Apple Watch als Gerät"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu Apple Watch como dispositivo"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il tuo Apple Watch come dispositivo"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "作为一台设备的你的 Apple Watch"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "作為一台裝置的你的 Apple Watch"
          }
        }
      }
    },
    "Your Charge (recovery) on the watch face, with Effort and Rest in the rectangular card.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Deine Erholung (Erholung) auf dem Zifferblatt, mit Belastung und Schlaf in der rechteckigen Karte."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu Carga (recuperación) en la esfera del reloj, con Esfuerzo y Descanso en la tarjeta rectangular."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La tua Carica (recupero) sul quadrante, con Sforzo e Riposo nella scheda rettangolare."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "表盘上显示你的能量（恢复），矩形卡片中显示消耗和休息。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "錶面上顯示你的能量（恢復），矩形卡片中則是消耗與休息。"
          }
        }
      }
    },
    "Your Charge score learns a personal baseline from your heart-rate variability, resting heart rate and more over time. If a bad first week set it off, you can re-learn it from tonight. Your history stays.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dein Ladungswert lernt mit der Zeit eine persönliche Basislinie aus deiner Herzfrequenzvariabilität, Ruheherzfrequenz und mehr. Wenn eine schlechte erste Woche sie verzerrt hat, kannst du sie ab heute Nacht neu lernen lassen. Dein Verlauf bleibt."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu puntuación de Carga aprende una línea base personal a partir de tu variabilidad de la frecuencia cardíaca, tu frecuencia cardíaca en reposo y más con el tiempo. Si una mala primera semana la desvió, puedes volver a aprenderla desde esta noche. Tu historial se conserva."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il tuo punteggio di carica impara una linea di base personale dalla tua variabilità della frequenza cardiaca, dalla FC a riposo e altro nel tempo. Se una prima settimana storta l'ha sballato, puoi farglielo reimparare a partire da stanotte. La tua cronologia rimane."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你的能量评分会随着时间从你的心率变异性、静息心率等中学习出一个个人基线。如果糟糕的第一周使它出现偏差，你可以从今晚起重新学习它。你的历史会保留。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "你的能量評分會隨著時間從你的心率變異性、靜息心率等中學習出一個個人基線。如果糟糕的第一週使它出現偏差，你可以從今晚起重新學習它。你的歷史會保留。"
          }
        }
      }
    },
    "Your Data, Fused": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Deine Daten, zusammengeführt"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tus datos, fusionados"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I tuoi dati, fusi insieme"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你的数据，已融合"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "你的資料，已融合"
          }
        }
      }
    },
    "Your GPS route for this session, recorded and stored on your device. Nothing leaves your phone.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Deine GPS-Route für diese Sitzung, aufgezeichnet und auf deinem Gerät gespeichert. Nichts verlässt dein Telefon."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu ruta GPS de esta sesión, grabada y almacenada en tu dispositivo. Nada sale de tu teléfono."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il tuo percorso GPS per questa sessione, registrato e archiviato sul tuo dispositivo. Nulla esce dal tuo telefono."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "本次会话的 GPS 路线，记录并存储在你的设备上。没有任何内容离开你的手机。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "本次工作階段的 GPS 路線，記錄並儲存在你的裝置上。沒有任何內容離開你的手機。"
          }
        }
      }
    },
    "Your HRV dipped while you were still. Want a minute to breathe?": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Deine HRV ist gesunken, während du still warst. Eine Minute zum Atmen?"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu VFC bajó mientras estabas en reposo. ¿Quieres un minuto para respirar?"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il tuo HRV è calato mentre eri fermo, vuoi un minuto per respirare?"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你静止时 HRV 出现了下降，想花一分钟呼吸一下吗？"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "你靜止時 HRV 出現了下降，想花一分鐘呼吸一下嗎？"
          }
        }
      }
    },
    "Your Monday-to-Sunday, read in one glance.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dein Montag bis Sonntag, auf einen Blick gelesen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu semana de lunes a domingo, de un vistazo."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il tuo lunedì-domenica, letto con un colpo d'occhio."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你从周一到周日的情况，一眼看懂。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "你從週一到週日的情況，一眼看懂。"
          }
        }
      }
    },
    "Your WHOOP 5/MG won't arm this until Experimental mode is on (Settings, Experimental). Right now your wake time is saved but the strap is NOT armed. Even with Experimental on, a 5/MG strap-driven wake is still unconfirmed on our side, so keep a backup alarm.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dein WHOOP 5/MG stellt das erst scharf, wenn der Experimentell-Modus an ist (Einstellungen, Experimentell). Gerade ist deine Aufwachzeit gespeichert, aber der Strap ist NICHT scharfgestellt. Selbst mit Experimentell an ist ein 5/MG-Strap-gesteuertes Wecken unsererseits noch unbestätigt, also halte einen Ersatzwecker bereit."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu WHOOP 5/MG no armará esto hasta que actives el modo experimental (Ajustes, Experimental). Ahora mismo tu hora de despertar está guardada pero la pulsera NO está armada. Incluso con Experimental activado, el despertar desde una pulsera 5/MG sigue sin confirmarse de nuestro lado, así que mantén una alarma de respaldo."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il tuo WHOOP 5/MG non attiverà questa funzione finché la modalità Sperimentale non è attiva (Impostazioni, Sperimentale). Per ora l'ora di sveglia è salvata ma la fascia NON è armata. Anche con la modalità Sperimentale attiva, una sveglia gestita dalla fascia 5/MG non è ancora confermata da parte nostra, quindi tieni una sveglia di riserva."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在实验模式开启之前（设置，实验），你的 WHOOP 5/MG 不会设定此项。目前你的起床时间已保存，但手环尚未设定。即使开启了实验模式，由 5/MG 手环驱动的唤醒在我们这边仍未得到确认，因此请保留一个备用闹钟。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在實驗模式開啟之前（設定，實驗），你的 WHOOP 5/MG 不會設定此項。目前你的起床時間已保存，但手環尚未設定。即使開啟了實驗模式，由 5/MG 手環驅動的喚醒在我們這邊仍未得到確認，因此請保留一個備用鬧鐘。"
          }
        }
      }
    },
    "Your WHOOP is at 100%.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dein WHOOP ist bei 100 %."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu WHOOP está al 100%."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il tuo WHOOP è al 100%."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你的 WHOOP 电量为 100%。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "你的 WHOOP 電量已達 100%。"
          }
        }
      }
    },
    "Your WHOOP only talks to one phone at a time.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dein WHOOP spricht immer nur mit einem Telefon."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu WHOOP solo habla con un teléfono a la vez."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il tuo WHOOP comunica con un solo telefono alla volta."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你的 WHOOP 同一时间只与一部手机通信。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "你的 WHOOP 同一時間只與一部手機通信。"
          }
        }
      }
    },
    "Your autonomic markers are skewed toward stress today. Treat it as a recovery-focused day.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Deine autonomen Marker neigen heute Richtung Stress. Behandle es als Tag mit Fokus auf Erholung."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tus marcadores autonómicos están inclinados hacia el estrés hoy. Tómalo como un día enfocado en la recuperación."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Oggi i tuoi marcatori autonomici pendono verso lo stress. Trattala come una giornata dedicata al recupero."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你今天的自主神经指标偏向压力。把今天当作以恢复为主的一天。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "你今天的自律神經指標偏向壓力，把今天當作以恢復為主的一天。"
          }
        }
      }
    },
    "Your bands report different numbers. Here's every source, and the one NOOP is using.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Deine Bänder melden unterschiedliche Zahlen. Hier ist jede Quelle und die, die NOOP verwendet."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tus bandas reportan números distintos. Aquí está cada fuente, y la que NOOP está usando."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Le tue fasce riportano numeri diversi. Ecco ogni sorgente, e quella che NOOP sta usando."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你的手环报告了不同的数字。这里是每一个来源，以及 NOOP 正在使用的那一个。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "你的手環報告了不同的數字。這裡是每一個來源，以及 NOOP 正在使用的那一個。"
          }
        }
      }
    },
    "Your bloods, BP and body numbers. Kept private, on %@.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Deine Blutwerte, dein Blutdruck und deine Körperwerte. Privat gehalten, auf %@."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tus análisis de sangre, presión arterial y datos corporales. Privados, en %@."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I tuoi esami del sangue, la pressione e i parametri corporei, mantenuti privati, su %@."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你的血液检查、血压和身体数据，私密保存，在 %@ 上。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "你的血液檢查、血壓和身體數據，私密保存，在 %@ 上。"
          }
        }
      }
    },
    "Your cardiovascular load. NOOP turns every second of heart rate into a training-impulse using heart-rate-reserve zones (Karvonen), weights time in harder zones more heavily (Edwards / Banister), and places it on a logarithmic 0–100 scale, so easy days sit low and an all-out day approaches 100, which stays genuinely rare. A long walk with little cardio still counts, through a steps / active-energy floor.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Deine kardiovaskuläre Last. NOOP verwandelt jede Sekunde Herzfrequenz über Herzfrequenzreserve-Zonen (Karvonen) in einen Trainingsimpuls, gewichtet Zeit in härteren Zonen stärker (Edwards / Banister) und legt das auf eine logarithmische Skala von 0–100 – lockere Tage liegen niedrig, ein Maximaltag nähert sich 100, was wirklich selten bleibt. Ein langer Spaziergang mit wenig Cardio zählt trotzdem, über einen Boden aus Schritten / aktiver Energie."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu carga cardiovascular. NOOP convierte cada segundo de frecuencia cardíaca en un impulso de entrenamiento usando zonas de reserva de frecuencia cardíaca (Karvonen), pondera más el tiempo en zonas duras (Edwards / Banister) y lo coloca en una escala logarítmica de 0–100, así los días fáciles quedan bajos y un día al límite se acerca a 100, algo genuinamente raro. Una caminata larga con poco cardio también cuenta, mediante un piso de pasos / energía activa."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il tuo carico cardiovascolare. NOOP trasforma ogni secondo di frequenza cardiaca in un impulso di allenamento usando le zone di riserva di frequenza cardiaca (Karvonen), pesa di più il tempo nelle zone più dure (Edwards / Banister) e lo colloca su una scala logaritmica da 0 a 100, così le giornate facili restano in basso e una giornata al massimo si avvicina a 100, cosa che resta davvero rara. Una lunga camminata con poco cardio conta comunque, grazie a una soglia minima basata su passi ed energia attiva."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你的心血管负荷。NOOP 使用心率储备区间（Karvonen）把每一秒心率转化为训练冲量，对更高强度区间的时间给予更大权重（Edwards / Banister），并将其放在 0–100 的对数刻度上，因此轻松的日子分数偏低，全力以赴的一天接近 100，而这种情况确实罕见。心肺负荷不高的长距离步行也会通过步数 / 活动能量下限计入。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "你的心血管負荷。NOOP 使用心率儲備區間（Karvonen）將每一秒的心率轉換為訓練衝量，對較高強度區間的時間給予更大權重（Edwards / Banister），並將其放在 0–100 的對數刻度上：輕鬆的日子分數低，全力以赴的一天接近 100，而這種情況確實罕見。透過步數／活動能量的下限機制，心肺負荷不高的長距離步行也會計入。"
          }
        }
      }
    },

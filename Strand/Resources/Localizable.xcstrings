        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Ricevi una notifica quando la batteria della fascia è quasi scarica (15%) così puoi ricaricarla prima di stanotte, e quando finisce di caricarsi."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "手环电量低（15%）时收到通知，好在今晚前充上电；充满时也会通知。"

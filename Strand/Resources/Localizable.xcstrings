    "Flags accepted, but the enable sequence doesn't start a separate live stream. The deep records arrive as part of the normal history sync (#494).": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Flags akzeptiert, aber die Aktivierungssequenz startet keinen separaten Live-Stream. Die Deep-Datensätze kommen als Teil der normalen Verlaufssynchronisierung an (#494)."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Indicadores aceptados, pero la secuencia de activación no inicia una transmisión en vivo separada. Los registros profundos llegan como parte de la sincronización normal del historial (#494)."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Flag accettati, ma la sequenza di attivazione non avvia un flusso in diretta separato, i record dettagliati arrivano come parte della normale sincronizzazione della cronologia (#494)."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "标志位已接受，但启用序列不会启动一个独立的实时流，深度记录会作为常规历史同步的一部分到达（#494）。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "旗標已接受，但啟用序列不會啟動一個獨立的即時流，深度記錄會作為常規歷史同步的一部分到達（#494）。"
          }
        }
      }
    },
    "Follicular": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Follikelphase"
          }
        },
        "es": {

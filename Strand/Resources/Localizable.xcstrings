    "Locked %@ · paces drift, re-measure anytime.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Fixiert %@ · Tempi driften, jederzeit neu messbar."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Bloqueado %@ · los ritmos varían, vuelve a medir cuando quieras."
          }
        },

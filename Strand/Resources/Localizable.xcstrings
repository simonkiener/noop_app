    "All of this is computed on your own device from data you already have. No heartbeat data leaves it.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "All das wird auf deinem eigenen Gerät aus Daten berechnet, die du bereits hast. Keine Herzschlagdaten verlassen es."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Todo esto se calcula en tu propio dispositivo a partir de datos que ya tienes. Ningún dato de latidos sale de él."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Tutto questo viene calcolato sul tuo dispositivo dai dati che hai già. Nessun dato del battito cardiaco lo lascia."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这一切都是在你自己的设备上、用你已有的数据计算得出的。任何心跳数据都不会离开设备。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "這一切都是在你自己的裝置上，用你已有的資料計算的。沒有任何心跳資料離開裝置。"
          }
        }
      }
    },
    "All stays on %@. Nothing is sent anywhere.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Alles bleibt auf %@. Nichts wird irgendwohin gesendet."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Todo permanece en %@. No se envía nada a ninguna parte."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",

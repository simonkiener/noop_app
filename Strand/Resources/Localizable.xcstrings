          }
        }
      }
    },
    "Insights read your journal and outcomes. Import your WHOOP export, which includes your journal, in Data Sources to unlock them.": {
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Einblicke lesen dein Journal und deine Ergebnisse. Importiere deinen WHOOP-Export, der dein Journal enthält, unter Datenquellen, um sie freizuschalten."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Insights read your journal and outcomes. Import your WHOOP export, which includes your journal, in Data Sources to unlock them."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los análisis leen tu diario y tus resultados. Importa tu exportación de WHOOP, que incluye tu diario, en Fuentes de datos para desbloquearlos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les perspectives lisent votre journal et vos résultats. Importez votre export WHOOP, qui inclut votre journal, dans Sources de données pour les débloquer."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Gli Approfondimenti leggono il tuo diario e i risultati. Importa la tua esportazione WHOOP, che include il tuo diario, in Sorgenti dati per sbloccarli."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выводы строятся на данных из вашего журнала и результатах. Чтобы открыть их, импортируйте данные WHOOP, включая журнал, в разделе «Источники данных»."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "洞察会读取你的日志和结果。请在「数据来源」中导入包含日志的 WHOOP 导出文件来解锁它们。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "洞察會讀取你的日誌和結果。請在「資料來源」中匯入包含日誌的 WHOOP 匯出檔案來解鎖它們。"
          }
        }
      }
    },
    "Installed outside the App Store": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Außerhalb des App Store installiert"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Instalado fuera del App Store"
          }
        },
        "it": {
          "stringUnit": {

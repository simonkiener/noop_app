    },
    "No workouts yet. They come from your WHOOP and Apple Health history. Import in Data Sources to bring them in, or add one you tracked elsewhere.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Noch keine Workouts. Sie kommen aus deinem WHOOP- und Apple-Health-Verlauf. Importiere unter „Datenquellen“, um sie hereinzuholen, oder füge eines hinzu, das du woanders erfasst hast."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Aún no hay entrenamientos. Provienen de tu historial de WHOOP y Apple Health. Impórtalos en Fuentes de datos para añadirlos, o añade uno que hayas registrado en otro sitio."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Ancora nessun allenamento. Provengono dalla cronologia del tuo WHOOP e di Apple Health. Importa in Sorgenti dati per acquisirli, oppure aggiungine uno che hai tracciato altrove."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "暂无锻炼记录。它们来自你的 WHOOP 和 Apple 健康历史。请在「数据来源」中导入以引入它们，或添加一次你在别处追踪的锻炼。"
          }
        },
        "zh-Hant": {
          "stringUnit": {

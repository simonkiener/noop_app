    "Mostly steady, with a few isolated extra or skipped beats. Very common and usually nothing.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Überwiegend gleichmäßig, mit ein paar vereinzelten zusätzlichen oder ausgelassenen Schlägen. Sehr häufig und meist nichts."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mayormente estable, con algunos latidos extra o saltados aislados. Muy común y normalmente sin importancia."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Per lo più regolare, con qualche battito extra o saltato isolato. Molto comune e di solito niente di che."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "大体平稳，偶有零星的多搏或漏搏。非常常见，通常无碍。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "大致平穩，只有少數零星的多跳或漏跳。非常常見，通常沒什麼。"
          }
        }
      }
    },

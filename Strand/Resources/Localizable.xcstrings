          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Risveglia la tua Mi Band e assicurati che in questo momento non sia connessa all'app Mi Fitness / Zepp Life."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "唤醒你的 Mi Band，并确保它此刻没有连接到 Mi Fitness / Zepp Life 应用。"
          }
        },
        "zh-Hant": {

    "Removes this recorded sleep and recomputes the day without it. This can't be undone.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Entfernt diesen aufgezeichneten Schlaf und berechnet den Tag ohne ihn neu. Das kann nicht rückgängig gemacht werden."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elimina este sueño registrado y recalcula el día sin él. Esto no se puede deshacer."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Rimuove questo sonno registrato e ricalcola il giorno senza di esso. Questa azione non può essere annullata."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "移除这条已记录的睡眠，并在没有它的情况下重新计算当天。此操作无法撤销。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "移除這筆已記錄的睡眠，並在沒有它的情況下重新計算當天。此操作無法撤銷。"
          }
        }

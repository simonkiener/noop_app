        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "报告错误时抓取此内容，它会告诉我应用看到了什么。（完整的实时日志也在「实时」界面上。）"
          }
        },
        "zh-Hant": {
          "stringUnit": {

    "Remove a question to tidy your list. Custom questions are deleted; the built-in ones are hidden and can be restored below.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Entferne eine Frage, um deine Liste aufzuräumen. Eigene Fragen werden gelöscht; die eingebauten werden ausgeblendet und lassen sich unten wiederherstellen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elimina una pregunta para ordenar tu lista. Las preguntas personalizadas se borran; las integradas se ocultan y pueden restaurarse abajo."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Rimuovi una domanda per riordinare la tua lista. Le domande personalizzate vengono eliminate; quelle integrate vengono nascoste e possono essere ripristinate qui sotto."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "移除一个问题以整理你的列表。自定义问题会被删除；内置问题会被隐藏，可在下方恢复。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "移除一個問題以整理你的列表。自訂問題會被刪除；內建問題會被隱藏，可在下方恢復。"
          }
        }
      }
    },

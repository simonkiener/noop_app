    "Time in each %HRmax zone, derived from the strap's heart rate over this window (approximate).": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Zeit in jeder %HRmax-Zone, abgeleitet aus der Herzfrequenz des Straps über dieses Fenster (ungefähr)."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tiempo en cada zona de %HRmax, derivado de la frecuencia cardíaca de la pulsera en esta ventana (aproximado)."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Tempo in ciascuna zona %HRmax, derivato dalla frequenza cardiaca della fascia in questo intervallo, approssimativo."
          }

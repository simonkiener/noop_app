          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Scegli l'aspetto di NOOP. Tutta l'app si aggiorna mentre tocchi. Puoi cambiarlo in qualsiasi momento in Impostazioni → Aspetto."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择 NOOP 的外观。点按即可全局生效。之后随时可在设置 → 外观中更改。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "選擇 NOOP 的外觀。點擊後整個應用程式會即時更新。你隨時可以在「設定 → 外觀」中更改。"
          }
        }
      }
    },
    "Choose how distances, weights, heights, temperatures and Effort are shown. Your data is always stored the same way. This only changes the display.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wähle, wie Distanzen, Gewichte, Größen, Temperaturen und Belastung angezeigt werden. Deine Daten werden immer gleich gespeichert. Das ändert nur die Anzeige."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elige cómo se muestran las distancias, pesos, alturas, temperaturas y Esfuerzo. Tus datos siempre se almacenan igual. Esto solo cambia la visualización."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Scegli come vengono mostrati distanze, pesi, altezze, temperature e sforzo. I tuoi dati vengono sempre memorizzati allo stesso modo, questo cambia solo la visualizzazione."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择距离、体重、身高、温度和消耗的显示方式。你的数据始终以相同方式存储，这只改变显示。"
          }
        },

    "Broadcasts the live heart rate NOOP derives from the strap once connected.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sendet die Live-Herzfrequenz, die NOOP aus dem Strap ableitet, sobald verbunden."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Difunde la frecuencia cardíaca en vivo que NOOP obtiene de la pulsera una vez conectada."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Trasmette la frequenza cardiaca in diretta che NOOP ricava dalla fascia una volta connessa."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "连接后广播 NOOP 从手环解析出的实时心率。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "連接後，廣播 NOOP 從手環推算出的即時心率。"
          }
        }
      }

    "“Dose” here is timing (later in the day = stronger), not milligrams.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "„Dosis“ heißt hier Timing (später am Tag = stärker), nicht Milligramm."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Aquí la “dosis” es el horario (más tarde en el día = más fuerte), no los miligramos."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Qui la “dose” è il momento (più tardi nella giornata = più forte), non i milligrammi."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这里的「剂量」指的是时间（越晚 = 越强），而非毫克数。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "這裡的「劑量」指的是時間（越晚 = 越強），而非毫克數。"
          }
        }
      }
    },

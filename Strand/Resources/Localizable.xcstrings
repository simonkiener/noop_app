    "Shows a soft sunrise, day, dusk and night scene behind the Today screen. Turn it off for a plain dark canvas. Your cards stay exactly as readable.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Zeigt eine sanfte Szene aus Sonnenaufgang, Tag, Dämmerung und Nacht hinter dem Heute-Bildschirm. Schalte es aus für eine schlichte dunkle Fläche. Deine Karten bleiben genauso lesbar."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Muestra una escena suave de amanecer, día, atardecer y noche detrás de la pantalla Hoy. Desactívalo para un fondo oscuro liso. Tus tarjetas siguen siendo igual de legibles."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Mostra una delicata scena di alba, giorno, tramonto e notte dietro la schermata Oggi. Disattivalo per uno sfondo scuro semplice, le tue schede restano altrettanto leggibili."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在「今天」界面背后显示柔和的日出、白天、黄昏和夜晚场景。将它关闭可获得纯粹的深色画布，你的卡片依然同样清晰易读。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在「今天」畫面背後顯示柔和的日出、白天、黃昏和夜晚場景。將它關閉可獲得純粹的深色畫布，你的卡片依然同樣清晰易讀。"
          }
        }
      }
    },

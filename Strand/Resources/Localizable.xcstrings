          }
        }
      }
    },
    "Wake your strap. Put it on, or dampen the contacts.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wecke deinen Strap. Leg ihn an oder befeuchte die Kontakte."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Despierta tu pulsera. Póntela o humedece los contactos."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Risveglia la tua fascia. Indossala, oppure inumidisci i contatti."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "唤醒你的手环。戴上它，或把触点弄湿。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "喚醒你的手環。戴上它，或沾濕接觸點。"
          }
        }
      }
    },

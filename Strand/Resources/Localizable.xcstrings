    "Live heart rate, and HRV when the ring can measure it.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Live-Herzfrequenz, und HRV, wenn der Ring sie messen kann."
          }
        },

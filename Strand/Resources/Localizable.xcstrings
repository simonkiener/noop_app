    "Strain nudges and your smart alarm tap your wrist the moment they fire.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Belastungs-Anstöße und dein Smart-Wecker tippen dein Handgelenk an, sobald sie auslösen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los avisos de esfuerzo y tu alarma inteligente tocan tu muñeca en el momento en que se activan."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Gli avvisi di Carico e la sveglia smart ti toccano il polso nel momento in cui scattano."

    "Self-tracking, not a clinical assessment. If low mood persists, talk to a professional. You deserve support.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Selbstbeobachtung, keine klinische Beurteilung. Wenn gedrückte Stimmung anhält, sprich mit Fachpersonal. Du verdienst Unterstützung."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Autoseguimiento, no una evaluación clínica. Si el ánimo bajo persiste, habla con un profesional. Mereces apoyo."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Auto-monitoraggio, non una valutazione clinica. Se l'umore basso persiste, parla con un professionista, meriti supporto."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "自我追踪，而非临床评估。如果低落情绪持续存在，请咨询专业人士，你值得获得支持。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "自我追蹤，而非臨床評估。如果低落情緒持續存在，請諮詢專業人士，你值得獲得支持。"
          }
        }
      }
    },

          }
        }
      }
    },
    "Not enough overlap between your journal answers and %@ to measure an effect yet. Keep logging. Effects need days both with and without each behaviour.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Noch nicht genug Überlappung zwischen deinen Tagebuch-Antworten und %@, um einen Effekt zu messen. Erfasse weiter. Effekte brauchen Tage mit und ohne jedes Verhalten."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Aún no hay suficiente solapamiento entre tus respuestas del diario y %@ para medir un efecto. Sigue registrando. Los efectos necesitan días tanto con cada comportamiento como sin él."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Non c'è ancora abbastanza sovrapposizione tra le risposte del tuo diario e %@ per misurare un effetto. Continua a registrare. Gli effetti richiedono giorni sia con che senza ogni comportamento."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你的日志回答与%@之间的重叠还不足以衡量影响。继续记录吧。衡量影响需要既有做和没做该行为的日子。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "你的日誌回答與 %@ 之間的重疊還不夠，尚無法測量效果。請持續記錄。每個行為都需要有做與沒做的日子才能看出效果。"
          }
        }
      }
    },
    "Not enough overlap between your journal answers and %@ yet. Keep logging. Each behaviour needs days both with and without it before NOOP can read its effect.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Noch nicht genug Überlappung zwischen deinen Tagebuch-Antworten und %@. Erfasse weiter. Jedes Verhalten braucht Tage mit und ohne, bevor NOOP seinen Effekt lesen kann."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Aún no hay suficiente solapamiento entre tus respuestas del diario y %@. Sigue registrando. Cada comportamiento necesita días tanto con él como sin él antes de que NOOP pueda leer su efecto."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Non c'è ancora abbastanza sovrapposizione tra le risposte del tuo diario e %@. Continua a registrare. Ogni comportamento richiede giorni sia con che senza prima che NOOP possa leggerne l'effetto."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你的日志回答与%@之间的重叠还不够。继续记录吧。每个行为都需要既有做和没做的日子，NOOP 才能读出它的影响。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "你的日誌回答與 %@ 之間的重疊還不夠。請持續記錄。每個行為都需要有做與沒做的日子，NOOP 才能讀出它的效果。"
          }
        }
      }
    },
    "Not enough overlapping days between these metrics in %@. Widen the range.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Nicht genug überlappende Tage zwischen diesen Metriken in %@. Erweitere den Bereich."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Not enough overlapping days between these metrics in %@. Widen the range."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No hay suficientes días solapados entre estas métricas en %@. Amplía el rango."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pas assez de jours chevauchants entre ces métriques dans %@. Élargissez la plage."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Giorni sovrapposti insufficienti tra queste metriche in %@. Amplia l'intervallo."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Недостаточно совпадающих дней между этими показателями за %@. Расширьте диапазон."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ 内这些指标之间的重叠天数不足。请扩大范围。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ 內這些指標之間的重疊天數不足。請擴大範圍。"
          }
        }
      }
    },
    "Not enough overlapping history to correlate your metrics yet.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Noch nicht genug überlappender Verlauf, um deine Metriken zu korrelieren."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Not enough overlapping history to correlate your metrics yet."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Aún no hay suficiente historial solapado para correlacionar tus métricas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pas encore assez d'historique chevauchant pour corréler vos métriques."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Cronologia sovrapposta ancora insufficiente per correlare le tue metriche."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Пока недостаточно общей истории, чтобы рассчитать связь между показателями."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "重叠的历史还不足以对你的指标进行相关性分析。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "重疊的歷史還不足以對你的指標進行相關性分析。"
          }
        }
      }
    },
    "Not enough recent days to chart a trend yet. Import a history or keep wearing your strap.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Noch nicht genug aktuelle Tage, um einen Trend darzustellen. Importiere eine Historie oder trage deinen Strap weiter."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Not enough recent days to chart a trend yet. Import a history or keep wearing your strap."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Aún no hay suficientes días recientes para trazar una tendencia. Importa un historial o sigue llevando tu pulsera."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pas encore assez de jours récents pour tracer une tendance. Importez un historique ou continuez à porter votre bracelet."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Giorni recenti ancora insufficienti per tracciare un andamento. Importa una cronologia o continua a indossare la tua fascia."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Пока недостаточно недавних данных, чтобы построить тренд. Импортируйте историю или продолжайте носить браслет."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "近期天数还不足以绘制趋势。请导入历史，或继续佩戴你的手环。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "近期天數還不足以繪製趨勢。請匯入歷史，或繼續佩戴你的手環。"
          }
        }
      }
    },

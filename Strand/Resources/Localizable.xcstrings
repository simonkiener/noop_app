    "Re-anchors every baseline that feeds Charge to your recent nights. No stored day is deleted.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verankert jede Basislinie, die in die Erholung einfließt, neu an deinen letzten Nächten. Kein gespeicherter Tag wird gelöscht."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Vuelve a anclar todas las líneas base que alimentan la Carga a tus noches recientes. No se elimina ningún día almacenado."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Riancora alle tue notti recenti ogni linea di base che alimenta la carica. Nessun giorno memorizzato viene eliminato."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "将所有为能量提供数据的基线重新锚定到你近期的夜晚。不会删除任何已存储的日期。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "將所有為能量提供資料的基線重新錨定到你近期的夜晚。不會刪除任何已儲存的日期。"
          }
        }
      }
    },

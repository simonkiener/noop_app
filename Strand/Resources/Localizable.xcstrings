        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Registra un entrenamiento manualmente. Guarda la frecuencia cardíaca y el esfuerzo hasta que lo termines."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Traccia un allenamento manualmente, registra frequenza cardiaca e sforzo finché non lo termini."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "手动追踪一次锻炼，记录心率和消耗，直到你结束它。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "手動追蹤一次鍛鍊，記錄心率和消耗，直到你結束它。"
          }
        }
      }
    },

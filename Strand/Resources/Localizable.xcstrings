    "Heads-up. Your WHOOP only talks to one phone at a time. Force-quit the official WHOOP app first, or pairing may fail.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Hinweis: Dein WHOOP spricht immer nur mit einem Telefon. Beende zuerst die offizielle WHOOP-App vollständig, sonst kann die Kopplung fehlschlagen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Aviso. Tu WHOOP solo habla con un teléfono a la vez. Fuerza el cierre de la app oficial de WHOOP primero, o el emparejamiento puede fallar."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Attenzione. Il tuo WHOOP comunica con un solo telefono alla volta. Chiudi forzatamente l'app ufficiale WHOOP prima, altrimenti l'abbinamento potrebbe fallire."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请注意。你的 WHOOP 同一时间只与一部手机通信。请先强制退出官方 WHOOP 应用，否则配对可能失败。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "請注意。你的 WHOOP 同一時間只與一部手機通信。請先強制退出官方 WHOOP 應用程式，否則配對可能失敗。"
          }
        }
      }
    },

    "Compare needs at least two metrics with history. Import your WHOOP export in Data Sources first.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Für den Vergleich werden mindestens zwei Metriken mit Verlauf benötigt. Importiere zuerst deinen WHOOP-Export unter Datenquellen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Compare needs at least two metrics with history. Import your WHOOP export in Data Sources first."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Comparar necesita al menos dos métricas con historial. Importa primero tu exportación de WHOOP en Fuentes de datos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Comparer nécessite au moins deux métriques avec un historique. Importez d'abord votre export WHOOP dans Sources de données."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il confronto richiede almeno due metriche con cronologia. Importa prima la tua esportazione WHOOP in Sorgenti dati."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Для сравнения нужны как минимум два показателя с историей. Сначала импортируйте данные WHOOP в разделе «Источники данных»."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "对比至少需要两项有历史记录的指标。请先在「数据来源」中导入你的 WHOOP 导出文件。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "對比至少需要兩項有歷史記錄的指標。請先在「資料來源」中匯入你的 WHOOP 匯出檔案。"
          }
        }

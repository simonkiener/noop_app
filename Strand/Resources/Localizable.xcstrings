    "%lld type-0x2F historical-offload frame%@ seen outside our sync. These are history (e.g. another app pulling the strap's backlog), not a live R22 stream (#494).": {
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$lld type-0x2F-Frame%2$@ (historischer Offload) außerhalb unserer Synchronisierung gesehen. Das ist Verlauf (z. B. eine andere App, die den Rückstand des Straps abruft), kein Live-R22-Stream (#494)."
          }
        },
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "%1$lld type-0x2F historical-offload frame%2$@ seen outside our sync, these are history (e.g. another app pulling the strap's backlog), not a live R22 stream (#494)."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld trama%@ de descarga histórica tipo 0x2F vistos fuera de nuestra sincronización. Son historial (p. ej., otra app extrayendo el archivo de la pulsera), no una transmisión R22 en vivo (#494)."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$lld frame%2$@ di scarico storico type-0x2F visti al di fuori della nostra sincronizzazione, sono cronologia (es. un'altra app che scarica l'arretrato della fascia), non uno stream R22 in diretta (#494)."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在我们的同步之外检测到 %1$lld 个 type-0x2F 历史卸载帧%2$@，这些是历史数据（例如另一个应用在拉取手环的积压数据），而非实时 R22 流（#494）。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在我們的同步之外偵測到 %1$lld 個 type-0x2F 歷史卸載幀%2$@，這些是歷史資料（例如另一個應用程式在拉取手環的積壓資料），而非即時 R22 流（#494）。"
          }
        }
      }
    },
    "%lld type-0x2F historical-offload frames seen outside our sync. These are history (e.g. another app pulling the strap's backlog), not a live R22 stream (#494).": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld type-0x2F-Frames (historischer Offload) außerhalb unserer Synchronisierung gesehen. Das ist Verlauf (z. B. eine andere App, die den Rückstand des Straps abruft), kein Live-R22-Stream (#494)."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld tramas de descarga histórica tipo 0x2F vistos fuera de nuestra sincronización. Son historial (p. ej., otra app extrayendo el archivo de la pulsera), no una transmisión R22 en vivo (#494)."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld frame di scaricamento storico type-0x2F visti fuori dalla nostra sincronizzazione. Si tratta di cronologia (per esempio un'altra app che scarica l'arretrato della fascia), non di un flusso R22 in tempo reale (#494)."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在我们的同步之外检测到 %lld 个 type-0x2F 历史卸载帧。这些是历史数据（例如另一个应用在拉取手环的积压数据），不是实时 R22 流（#494）。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在我們的同步之外偵測到 %lld 個 type-0x2F 歷史卸載幀。這些是歷史資料（例如另一個應用程式在拉取手環的積存資料），不是即時 R22 串流（#494）。"
          }
        }
      }
    },

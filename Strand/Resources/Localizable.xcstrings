            "state": "translated",
            "value": "Overlay signals, draw conclusions."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Superpón señales, saca conclusiones."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Superposez les signaux, tirez des conclusions."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Sovrapponi i segnali, trai le conclusioni."
          }
        },
        "ru": {

    "Live HR + R-R only · no sleep, recovery, skin temp, SpO₂, steps or battery (those are WHOOP-only).": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Nur Live-HF + R-R · kein Schlaf, keine Erholung, Hauttemperatur, SpO₂, Schritte oder Akku (das ist WHOOP vorbehalten)."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Solo FC en vivo + R-R · sin sueño, recuperación, temperatura de la piel, SpO₂, pasos ni batería (esos son solo de WHOOP)."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Solo FC in diretta + R-R · niente sonno, recupero, temperatura cutanea, SpO₂, passi o batteria (quelli sono solo WHOOP)."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "仅实时心率 + R-R · 无睡眠、恢复、皮肤温度、SpO₂、步数或电量（这些仅 WHOOP 提供）。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "僅即時心率 + R-R · 沒有睡眠、恢復、皮膚溫度、SpO₂、步數或電量（那些僅限 WHOOP）。"
          }
        }
      }
    },
    "Live HR works. Free the strap to unlock buzz, alarms & sync": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Live-HF funktioniert. Gib den Strap frei, um Vibration, Wecker & Sync freizuschalten"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La FC en vivo funciona. Libera la pulsera para desbloquear vibración, alarmas y sincronización"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La FC in diretta funziona, libera la fascia per sbloccare vibrazione, sveglie e sincronizzazione"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "实时心率可用，释放手环以解锁震动、闹钟和同步"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "即時心率可用，釋放手環以解鎖震動、鬧鐘和同步"
          }
        }
      }
    },

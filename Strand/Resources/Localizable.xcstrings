    "Wake the machine. Start pedalling, walking or rowing so it powers on its Bluetooth.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wecke das Gerät. Fang an zu treten, gehen oder rudern, damit es sein Bluetooth einschaltet."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Despierta la máquina. Empieza a pedalear, caminar o remar para que encienda su Bluetooth."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Risveglia la macchina. Inizia a pedalare, camminare o remare così accende il suo Bluetooth."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "唤醒器械。开始踩踏、行走或划船，让它开启 Bluetooth。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "喚醒機器。開始踩踏、走動或划船，讓它啟動 Bluetooth。"
          }
        }
      }
    },

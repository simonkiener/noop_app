          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "記錄一次你在別處追蹤的工作階段。"
          }
        }
      }
    },
    "Log a sleep mark": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Schlafmarke erfassen"
          }
        },

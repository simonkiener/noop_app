    "Based mostly on typical patterns, not yet yours. Log a few more %@ days and this becomes yours.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Basiert überwiegend auf typischen Mustern, noch nicht auf deinen. Erfasse ein paar weitere %@-Tage, dann wird es deins."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Basado sobre todo en patrones típicos, todavía no en los tuyos. Registra unos cuantos días más de %@ y esto pasará a ser tuyo."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Basato per lo più su schemi tipici, non ancora sui tuoi. Registra ancora qualche giorno di %@ e diventerà personalizzato."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "目前主要基于常见模式，还不是你自己的。再记录几天 %@，它就会变成你的专属数据。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "目前主要基於一般模式，還不是你自己的。再記錄幾天 %@，它就會屬於你。"
          }
        }
      }
    },

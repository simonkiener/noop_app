          }
        }
      }
    },
    "Import a WHOOP export, Apple Health or a second band and your best-sourced record builds here, on this device.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Importiere einen WHOOP-Export, Apple Health oder ein zweites Band, und deine bestmögliche Aufzeichnung entsteht hier, auf diesem Gerät."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Importa una exportación de WHOOP, Apple Health o una segunda banda y tu registro con la mejor fuente se construye aquí, en este dispositivo."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Importa un'esportazione WHOOP, Apple Health o una seconda fascia e il tuo record dalle migliori sorgenti si costruisce qui, su questo dispositivo."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "导入一份 WHOOP 导出文件、Apple 健康或第二条手环，你的最佳来源记录便会在这里构建，就在这台设备上。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "匯入一份 WHOOP 匯出檔案、Apple 健康或第二條手環，你的最佳來源記錄便會在這裡建立，就在這台裝置上。"
          }
        }
      }
    },
    "Import a single exported workout file from any brand (Garmin, Coros, Suunto, Wahoo, Polar, Strava, Apple) straight off your device. GPS route, distance, heart rate and calories come in where the file has them. Fully offline; nothing leaves %@.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Importiere eine einzelne exportierte Workout-Datei jeder Marke (Garmin, Coros, Suunto, Wahoo, Polar, Strava, Apple) direkt von deinem Gerät. GPS-Route, Distanz, Herzfrequenz und Kalorien kommen mit, wo die Datei sie enthält. Komplett offline; nichts verlässt %@."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Importa un único archivo de entrenamiento exportado de cualquier marca (Garmin, Coros, Suunto, Wahoo, Polar, Strava, Apple) directamente desde tu dispositivo. La ruta GPS, la distancia, la frecuencia cardíaca y las calorías se incorporan cuando el archivo las incluye. Totalmente sin conexión; nada sale de %@."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Importa un singolo file di allenamento esportato da qualsiasi marca (Garmin, Coros, Suunto, Wahoo, Polar, Strava, Apple) direttamente dal tuo dispositivo. Percorso GPS, distanza, frequenza cardiaca e calorie arrivano dove il file li contiene. Completamente offline; niente lascia %@."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "直接从设备导入任意品牌（Garmin、Coros、Suunto、Wahoo、Polar、Strava、Apple）导出的单个锻炼文件。文件中包含的 GPS 路线、距离、心率和卡路里都会导入。完全离线；任何数据都不会离开 %@。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "直接從你的裝置匯入任何品牌（Garmin、Coros、Suunto、Wahoo、Polar、Strava、Apple）匯出的單一鍛鍊檔案。只要檔案裡有，GPS 路線、距離、心率和卡路里都會匯入。完全離線；沒有任何內容離開 %@。"
          }
        }
      }
    },
    "Import an Apple Health export (Health app → profile → Export All Health Data → export.zip). 7 years of HR, HRV, sleep, SpO₂, steps and more, streamed locally. Large exports take a minute or two.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Importiere einen Apple-Health-Export (Health-App → Profil → Alle Gesundheitsdaten exportieren → export.zip). 7 Jahre HF, HRV, Schlaf, SpO₂, Schritte und mehr, lokal eingelesen. Große Exporte dauern ein bis zwei Minuten."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Importa una exportación de Apple Health (app Salud → perfil → Exportar todos los datos de salud → export.zip). 7 años de FC, VFC, sueño, SpO₂, pasos y más, procesados localmente. Las exportaciones grandes tardan uno o dos minutos."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Importa un'esportazione di Apple Health (app Salute → profilo → Esporta tutti i dati sanitari → export.zip). 7 anni di FC, HRV, sonno, SpO₂, passi e altro, elaborati in locale. Le esportazioni grandi richiedono un minuto o due."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "导入 Apple Health 导出文件（健康 App → 个人资料 → 导出所有健康数据 → export.zip）。7 年的心率、HRV、睡眠、SpO₂、步数等数据，全部本地处理。大文件需要一两分钟。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "匯入 Apple Health 匯出檔案（健康 App → 個人檔案 → 匯出所有健康資料 → export.zip）。7 年的心率、HRV、睡眠、SpO₂、步數等，在本機串流處理。較大的匯出檔案需要一兩分鐘。"
          }
        }
      }
    },
    "Import daily nutrition totals from a Cronometer or MacroFactor CSV export: calories in, protein, carbs, fat (and weight if present). Other trackers work too if the file has a date column and daily totals.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Importiere tägliche Ernährungssummen aus einem Cronometer- oder MacroFactor-CSV-Export: Kalorien, Protein, Kohlenhydrate, Fett (und Gewicht, falls vorhanden). Andere Tracker funktionieren auch, wenn die Datei eine Datumsspalte und Tagessummen hat."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Importa los totales diarios de nutrición desde una exportación CSV de Cronometer o MacroFactor: calorías ingeridas, proteína, carbohidratos, grasa (y peso si está presente). Otros registros también funcionan si el archivo tiene una columna de fecha y totales diarios."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Importa i totali nutrizionali giornalieri da un'esportazione CSV di Cronometer o MacroFactor: calorie assunte, proteine, carboidrati, grassi (e peso se presente). Funzionano anche altri tracker se il file ha una colonna data e i totali giornalieri."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "从 Cronometer 或 MacroFactor 的 CSV 导出文件导入每日营养总量：摄入卡路里、蛋白质、碳水、脂肪（如有体重也会导入）。其他记录工具只要文件包含日期列和每日总量也可以。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "從 Cronometer 或 MacroFactor 的 CSV 匯出檔案匯入每日營養總量：攝取卡路里、蛋白質、碳水化合物、脂肪（若有也包含體重）。只要檔案有日期欄和每日總量，其他追蹤器也適用。"
          }
        }
      }
    },
    "Import failed. Your existing data was kept. %@": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Import fehlgeschlagen. Deine bestehenden Daten wurden behalten. %@"

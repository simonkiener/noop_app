    "Waiting for a resting heart rate. Start a live reading first, or come back when you're still.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Warte auf eine Ruheherzfrequenz. Starte zuerst eine Live-Messung oder komm zurück, wenn du still bist."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esperando una frecuencia cardíaca en reposo. Inicia primero una lectura en vivo, o vuelve cuando estés quieto."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "In attesa di una frequenza cardiaca a riposo, avvia prima una lettura in diretta, oppure torna quando sei fermo."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "正在等待静息心率，请先开始一次实时读数，或在你静止时再回来。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "正在等待靜息心率，請先開始一次即時讀數，或在你靜止時再回來。"
          }
        }
      }
    },

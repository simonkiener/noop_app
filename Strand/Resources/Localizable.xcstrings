    "This stands on community reverse-engineering. Huge thanks:": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dies basiert auf Reverse-Engineering der Community. Großen Dank:"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This stands on community reverse-engineering. Huge thanks:"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto se apoya en la ingeniería inversa de la comunidad. Muchísimas gracias:"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ceci repose sur la rétro-ingénierie communautaire. Un immense merci :"
          }
        },
        "it": {

        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "表盘上显示你的能量（恢复），矩形卡片中显示消耗和休息。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "錶面上顯示你的能量（恢復），矩形卡片中則是消耗與休息。"
